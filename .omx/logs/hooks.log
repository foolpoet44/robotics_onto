s.data = null;\n    44\t    this.errors = [];\n    45\t    this.warnings = [];\n    46\t  }\n    47\t\n    48\t  load() {\n    49\t    try {\n    50\t      const content = fs.readFileSync(this.dataPath, \"utf-8\");\n    51\t      this.data = JSON.parse(content);\n    52\t      log(`✅ 데이터 로드 성공: ${this.dataPath}`, \"green\");\n    53\t      return true;\n    54\t    } catch (error) {\n    55\t      log(`❌ 데이터 로드 실패: ${error.message}`, \"red\");\n    56\t      return false;\n    57\t    }\n    58\t  }\n    59\t\n    60\t  // 1. 전체 스킬 수 검증\n    61\t  validateTotalSkills() {\n    62\t    header(\"1️⃣ 전체 스킬 수 검증\");\n    63\t\n    64\t    const totalSkills = this.data.length;\n    65\t    const minRequired = 120;\n    66\t\n    67\t    log(\n    68\t      `총 스킬 수: ${totalSkills}개`,\n    69\t      totalSkills >= minRequired ? \"green\" : \"red\",\n    70\t    );\n    71\t\n    72\t    if (totalSkills >= minRequired) {\n    73\t      log(`✅ 목표 달성 (목표: ${minRequired}개 이상)`, \"green\");\n    74\t    } else {\n    75\t      log(`⚠️ 부족: ${minRequired - totalSkills}개 더 필요`, \"yellow\");\n    76\t      this.warnings.push(`스킬 수 부족: ${totalSkills}/${minRequired}`);\n    77\t    }\n    78\t\n    79\t    return totalSkills;\n    80\t  }\n    81\t\n    82\t  // 2. 도메인별 분포 검증\n    83\t  validateDomainDistribution() {\n    84\t    header(\"2️⃣ 도메인별 분포 검증\");\n    85\t\n    86\t    const expectedDomains = [\n    87\t      \"industrial-robot-control\",\n    88\t      \"machine-vision-sensor\",\n    89\t      \"collaborative-robot\",\n    90\t      \"autonomous-mobile-robot\",\n    91\t      \"robot-maintenance-diagnostics\",\n    92\t      \"digital-twin-simulation\",\n    93\t    ];\n    94\t\n    95\t    const domainStats = {};\n    96\t    this.data.forEach((skill) => {\n    97\t      if (!domainStats[skill.domain]) {\n    98\t        domainStats[skill.domain] = 0;\n    99\t      }\n   100\t      domainStats[skill.domain]++;\n   101\t    });\n   102\t\n   103\t    const foundDomains = Object.keys(domainStats);\n   104\t    const missingDomains = expectedDomains.filter(\n   105\t      (d) => !foundDomains.includes(d),\n   106\t    );\n   107\t\n   108\t    // 도메인별 상세 정보\n   109\t    const table = [];\n   110\t    expectedDomains.forEach((domain) => {\n   111\t      const count = domainStats[domain] || 0;\n   112\t      const status = count > 0 ? \"✅\" : \"❌\";\n   113\t      table.push({\n   114\t        Domain: status,\n   115\t        Name: domain,\n   116\t        Count: count,\n   117\t      });\n   118\t    });\n   119\t\n   120\t    console.table(table);\n   121\t\n   122\t    if (missingDomains.length === 0) {\n   123\t      log(`✅ 모든 6개 도메인이 존재합니다.`, \"green\");\n   124\t    } else {\n   125\t      log(`❌ 누락된 도메인: ${missingDomains.join(\", \")}`, \"red\");\n   126\t      this.errors.push(`누락된 도메인: ${missingDomains.join(\", \")}`);\n   127\t    }\n   128\t\n   129\t    return domainStats;\n   130\t  }\n   131\t\n   132\t  // 3. skill_type별 분포 검증\n   133\t  validateSkillTypeDistribution() {\n   134\t    header(\"3️⃣ 스킬 타입별 분포 검증\");\n   135\t\n   136\t    const typeStats = {};\n   137\t    this.data.forEach((skill) => {\n   138\t      const type = skill.skill_type;\n   139\t      if (!typeStats[type]) {\n   140\t        typeStats[type] = 0;\n   141\t      }\n   142\t      typeStats[type]++;\n   143\t    });\n   144\t\n   145\t    const total = this.data.length;\n   146\t    const table = [];\n   147\t\n   148\t    Object.entries(typeStats).forEach(([type, count]) => {\n   149\t      const percentage = ((count / total) * 100).toFixed(1);\n   150\t      table.push({\n   151\t        Type: type,\n   152\t        Count: count,\n   153\t        Percentage: `${percentage}%`,\n   154\t      });\n   155\t    });\n   156\t\n   157\t    console.table(table);\n   158\t\n   159\t    // 3층 모두 존재하는지 확인\n   160\t    const expectedTypes = [\"knowledge\", \"skill\", \"competence\"];\n   161\t    const foundTypes = Object.keys(typeStats);\n   162\t    const allPresent = expectedTypes.every((t) => foundTypes.includes(t));\n   163\t\n   164\t    if (allPresent) {\n   165\t      log(`✅ 3층 계층 구조 모두 존재 (Knowledge, Skill, Competence)`, \"green\");\n   166\t    } else {\n   167\t      const missing = expectedTypes.filter((t) => !foundTypes.includes(t));\n   168\t      log(`❌ 누락된 스킬 타입: ${missing.join(\", \")}`, \"red\");\n   169\t      this.errors.push(`누락된 스킬 타입: ${missing.join(\", \")}`);\n   170\t    }\n   171\t\n   172\t    return typeStats;\n   173\t  }\n   174\t\n   175\t  // 4. role_mapping 커버리지 검증\n   176\t  validateRoleMapping() {\n   177\t    header(\"4️⃣ 역할 커버리지 검증\");\n   178\t\n   179\t    const roleStats = {};\n   180\t    const expectedRoles = [\"operator\", \"engineer\", \"developer\"];\n   181\t\n   182\t    this.data.forEach((skill) => {\n   183\t      skill.role_mapping.forEach((role) => {\n   184\t        if (!roleStats[role]) {\n   185\t          roleStats[role] = 0;\n   186\t        }\n   187\t        roleStats[role]++;\n   188\t      });\n   189\t    });\n   190\t\n   191\t    const table = [];\n   192\t    expectedRoles.forEach((role) => {\n   193\t      const count = roleStats[role] || 0;\n   194\t      const status = count > 0 ? \"✅\" : \"❌\";\n   195\t      table.push({\n   196\t        Role: status,\n   197\t        Name: role,\n   198\t        Count: count,\n   199\t      });\n   200\t    });\n   201\t\n   202\t    console.table(table);\n   203\t\n   204\t    // 모든 역할이 커버되는지 확인\n   205\t    const allCovered = expectedRoles.every(\n   206\t      (r) => roleStats[r] && roleStats[r] > 0,\n   207\t    );\n   208\t\n   209\t    if (allCovered) {\n   210\t      log(`✅ 3개 역할 모두 커버됨`, \"green\");\n   211\t    } else {\n   212\t      const missing = expectedRoles.filter(\n   213\t        (r) => !roleStats[r] || roleStats[r] === 0,\n   214\t      );\n   215\t      log(`❌ 누락된 역할: ${missing.join(\", \")}`, \"red\");\n   216\t      this.errors.push(`누락된 역할: ${missing.join(\", \")}`);\n   217\t    }\n   218\t\n   219\t    return roleStats;\n   220\t  }\n   221\t\n   222\t  // 5. 고아 스킬 탐지\n   223\t  validateOrphanSkills() {\n   224\t    header(\"5️⃣ 고아 스킬 탐지 (parent_skill_id 검증)\");\n   225\t\n   226\t    const skillIds = new Set(this.data.map((s) => s.skill_id));\n   227\t    const orphans = [];\n   228\t\n   229\t    this.data.forEach((skill) => {\n   230\t      if (skill.parent_skill_id && !skillIds.has(skill.parent_skill_id)) {\n   231\t        orphans.push({\n   232\t          skill_id: skill.skill_id,\n   233\t          parent_id: skill.parent_skill_id,\n   234\t          label: skill.preferred_label_ko,\n   235\t        });\n   236\t      }\n   237\t    });\n   238\t\n   239\t    if (orphans.length === 0) {\n   240\t      log(`✅ 고아 스킬 없음 (모든 parent_skill_id가 유효함)`, \"green\");\n   241\t    } else {\n   242\t      log(`⚠️ 고아 스킬 발견: ${orphans.length}개`, \"yellow\");\n   243\t      console.table(orphans);\n   244\t      this.warnings.push(`고아 스킬: ${orphans.length}개`);\n   245\t    }\n   246\t\n   247\t    return orphans;\n   248\t  }\n   249\t\n   250\t  // 6. related_skills 상호참조 검증\n   251\t  validateRelatedSkills() {\n   252\t    header(\"6️⃣ related_skills 상호참조 검증\");\n   253\t\n   254\t    const skillIds = new Set(this.data.map((s) => s.skill_id));\n   255\t    const invalidReferences = [];\n   256\t\n   257\t    this.data.forEach((skill) => {\n   258\t      if (skill.related_skills && Array.isArray(skill.related_skills)) {\n   259\t        skill.related_skills.forEach((relatedId) => {\n   260\t          if (!skillIds.has(relatedId)) {\n   261\t            invalidReferences.push({\n   262\t              skill_id: skill.skill_id,\n   263\t              invalid_reference: relatedId,\n   264\t            });\n   265\t          }\n   266\t        });\n   267\t      }\n   268\t    });\n   269\t\n   270\t    if (invalidReferences.length === 0) {\n   271\t      log(`✅ 모든 related_skills 참조가 유효함`, \"green\");\n   272\t    } else {\n   273\t      log(\n   274\t        `⚠️ 유효하지 않은 참조 발견: ${invalidReferences.length}개`,\n   275\t        \"yellow\",\n   276\t      );\n   277\t      console.table(invalidReferences);\n   278\t      this.warnings.push(`유효하지 않은 참조: ${invalidReferences.length}개`);\n   279\t    }\n   280\t\n   281\t    return invalidReferences;\n   282\t  }\n   283\t\n   284\t  // 7. 추가 통계: proficiency_level 분포\n   285\t  validateProficiencyDistribution() {\n   286\t    header(\"7️⃣ 숙련도 레벨 분포 검증\");\n   287\t\n   288\t    const profStats = {};\n   289\t    this.data.forEach((skill) => {\n   290\t      const level = skill.proficiency_level;\n   291\t      if (!profStats[level]) {\n   292\t        profStats[level] = 0;\n   293\t      }\n   294\t      profStats[level]++;\n   295\t    });\n   296\t\n   297\t    const table = [];\n   298\t    for (let level = 1; level <= 4; level++) {\n   299\t      const count = profStats[level] || 0;\n   300\t      const percentage = ((count / this.data.length) * 100).toFixed(1);\n   301\t      table.push({\n   302\t        Level: level,\n   303\t        Count: count,\n   304\t        Percentage: `${percentage}%`,\n   305\t      });\n   306\t    }\n   307\t\n   308\t    console.table(table);\n   309\t\n   310\t    // 모든 레벨이 표현되는지 확인\n   311\t    const allLevels = [1, 2, 3, 4].every(\n   312\t      (l) => profStats[l] && profStats[l] > 0,\n   313\t    );\n   314\t    if (allLevels) {\n   315\t      log(`✅ 4개 레벨 모두 표현됨`, \"green\");\n   316\t    } else {\n   317\t      log(`⚠️ 누락된 레벨이 있습니다.`, \"yellow\");\n   318\t    }\n   319\t\n   320\t    return profStats;\n   321\t  }\n   322\t\n   323\t  // 8. 필드 완성도 검증\n   324\t  validateFieldCompleteness() {\n   325\t    header(\"8️⃣ 필드 완성도 검증\");\n   326\t\n   327\t    const requiredFields = [\n   328\t      \"skill_id\",\n   329\t      \"domain\",\n   330\t      \"esco_uri\",\n   331\t      \"preferred_label_ko\",\n   332\t      \"preferred_label_en\",\n   333\t      \"skill_type\",\n   334\t      \"proficiency_level\",\n   335\t      \"role_mapping\",\n   336\t    ];\n   337\t\n   338\t    let incompleteCount = 0;\n   339\t\n   340\t    this.data.forEach((skill) => {\n   341\t      requiredFields.forEach((field) => {\n   342\t        if (\n   343\t          !skill[field] ||\n   344\t          skill[field] === \"\" ||\n   345\t          (Array.isArray(skill[field]) && skill[field].length === 0)\n   346\t        ) {\n   347\t          incompleteCount++;\n   348\t          this.errors.push(`스킬 ${skill.skill_id}: 필수 필드 '${field}' 누락`);\n   349\t        }\n   350\t      });\n   351\t    });\n   352\t\n   353\t    if (incompleteCount === 0) {\n   354\t      log(`✅ 모든 스킬의 필수 필드가 완성됨`, \"green\");\n   355\t    } else {\n   356\t      log(`❌ 불완전한 필드: ${incompleteCount}개`, \"red\");\n   357\t    }\n   358\t\n   359\t    return incompleteCount === 0;\n   360\t  }\n   361\t\n   362\t  // 최종 리포트\n   363\t  generateReport() {\n   364\t    header(\"📋 최종 검증 리포트\");\n   365\t\n   366\t    console.log(\"\\n\");\n   367\t    if (this.errors.length === 0) {\n   368\t      log(\"🎉 검증 완료: 모든 검증에 통과했습니다!\", \"green\");\n   369\t    } else {\n   370\t      log(`❌ 발견된 오류: ${this.errors.length}개`, \"red\");\n   371\t      this.errors.forEach((error) => log(`   - ${error}`, \"red\"));\n   372\t    }\n   373\t\n   374\t    if (this.warnings.length > 0) {\n   375\t      log(`\\n⚠️ 경고: ${this.warnings.length}개`, \"yellow\");\n   376\t      this.warnings.forEach((warning) => log(`   - ${warning}`, \"yellow\"));\n   377\t    }\n   378\t\n   379\t    console.log(\"\\n\" + \"=\".repeat(60));\n   380\t  }\n   381\t\n   382\t  run() {\n   383\t    if (!this.load()) {\n   384\t      return false;\n   385\t    }\n   386\t\n   387\t    const totalSkills = this.validateTotalSkills();\n   388\t    const domainStats = this.validateDomainDistribution();\n   389\t    const typeStats = this.validateSkillTypeDistribution();\n   390\t    const roleStats = this.validateRoleMapping();\n   391\t    const orphans = this.validateOrphanSkills();\n   392\t    const invalidReferences = this.validateRelatedSkills();\n   393\t    const profStats = this.validateProficiencyDistribution();\n   394\t    const fieldsComplete = this.validateFieldCompleteness();\n   395\t\n   396\t    // 최종 요약 테이블\n   397\t    header(\"📊 최종 요약\");\n   398\t    const summary = [\n   399\t      { Metric: \"총 스킬 수\", Value: totalSkills },\n   400\t      { Metric: \"도메인 수\", Value: Object.keys(domainStats).length },\n   401\t      { Metric: \"Knowledge 스킬\", Value: typeStats.knowledge || 0 },\n   402\t      { Metric: \"Skill 스킬\", Value: typeStats.skill || 0 },\n   403\t      { Metric: \"Competence 스킬\", Value: typeStats.competence || 0 },\n   404\t      { Metric: \"고아 스킬\", Value: orphans.length },\n   405\t      { Metric: \"유효하지 않은 참조\", Value: invalidReferences.length },\n   406\t    ];\n   407\t    console.table(summary);\n   408\t\n   409\t    this.generateReport();\n   410\t\n   411\t    return this.errors.length === 0;\n   412\t  }\n   413\t}\n   414\t\n   415\t// ==================== 메인 실행 ====================\n   416\tconst dataPath = path.join(__dirname, \"../public/data/robot-smartfactory.json\");\n   417\tconst validator = new RobotDataValidator(dataPath);\n   418\tconst success = validator.run();\n   419\t\n   420\tprocess.exit(success ? 0 : 1);\n\n--- TEST SCRIPT HEAD ---\n     1\t#!/usr/bin/env node\n     2\t\n     3\t/**\n     4\t * 로봇테크 for 스마트팩토리 프로젝트 종합 검증 테스트\n     5\t *\n     6\t * 테스트 범위:\n     7\t * 1. 파일 존재 여부 및 접근성\n     8\t * 2. JSON 형식 및 구조 유효성\n     9\t * 3. 데이터 무결성 (스키마 준수)\n    10\t * 4. 비즈니스 로직 검증 (도메인, 역할, 숙련도)\n    11\t * 5. 한영 데이터 완성도\n    12\t * 6. ESCO 표준 준수\n    13\t * 7. 설계 문서와 데이터 일관성\n    14\t */\n    15\t\n    16\tconst fs = require(\"fs\");\n    17\tconst path = require(\"path\");\n    18\t\n    19\t// ==================== 테스트 헬퍼 ====================\n    20\t\n    21\tlet testCount = 0;\n    22\tlet passCount = 0;\n    23\tlet failCount = 0;\n    24\tconst failedTests = [];\n    25\t\n    26\tconst colors = {\n    27\t  reset: \"\\x1b[0m\",\n    28\t  bright: \"\\x1b[1m\",\n    29\t  green: \"\\x1b[32m\",\n    30\t  red: \"\\x1b[31m\",\n    31\t  yellow: \"\\x1b[33m\",\n    32\t  cyan: \"\\x1b[36m\",\n    33\t  blue: \"\\x1b[34m\",\n    34\t};\n    35\t\n    36\tfunction assert(condition, message) {\n    37\t  testCount++;\n    38\t  if (condition) {\n    39\t    passCount++;\n    40\t    console.log(`${colors.green}✓${colors.reset} ${message}`);\n    41\t  } else {\n    42\t    failCount++;\n    43\t    failedTests.push(message);\n    44\t    console.log(`${colors.red}✗${colors.reset} ${message}`);\n    45\t  }\n    46\t}\n    47\t\n    48\tfunction testSection(title) {\n    49\t  console.log(\n    50\t    `\\n${colors.cyan}${colors.bright}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${colors.reset}`,\n    51\t  );\n    52\t  console.log(`${colors.cyan}${colors.bright}${title}${colors.reset}`);\n    53\t  console.log(\n    54\t    `${colors.cyan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${colors.reset}`,\n    55\t  );\n    56\t}\n    57\t\n    58\tfunction testResult() {\n    59\t  console.log(\n    60\t    `\\n${colors.cyan}${colors.bright}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${colors.reset}`,\n    61\t  );\n    62\t  console.log(`${colors.bright}테스트 결과 요약${colors.reset}`);\n    63\t  console.log(\n    64\t    `${colors.cyan}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${colors.reset}`,\n    65\t  );\n    66\t  console.log(`총 테스트: ${testCount}개`);\n    67\t  console.log(`${colors.green}통과: ${passCount}개${colors.reset}`);\n    68\t  console.log(`${colors.red}실패: ${failCount}개${colors.reset}`);\n    69\t\n    70\t  if (failCount > 0) {\n    71\t    console.log(`\\n${colors.red}${colors.bright}실패한 테스트:${colors.reset}`);\n    72\t    failedTests.forEach((test) => {\n    73\t      console.log(`  - ${test}`);\n    74\t    });\n    75\t  }\n    76\t\n    77\t  const percentage = ((passCount / testCount) * 100).toFixed(1);\n    78\t  console.log(`\\n통과율: ${percentage}%`);\n    79\t\n    80\t  if (failCount === 0) {\n    81\t    console.log(\n    82\t      `\\n${colors.green}${colors.bright}🎉 모든 테스트 통과!${colors.reset}`,\n    83\t    );\n    84\t    return true;\n    85\t  } else {\n    86\t    console.log(\n    87\t      `\\n${colors.red}${colors.bright}⚠️ 일부 테스트 실패${colors.reset}`,\n    88\t    );\n    89\t    return false;\n    90\t  }\n    91\t}\n    92\t\n    93\t// ==================== 테스트 로직 ====================\n    94\t\n    95\tclass RobotSmartFactoryTester {\n    96\t  constructor() {\n    97\t    this.skillData = null;\n    98\t    this.designDoc = null;\n    99\t    this.expectedDomains = [\n   100\t      \"industrial-robot-control\",\n   101\t      \"machine-vision-sensor\",\n   102\t      \"collaborative-robot\",\n   103\t      \"autonomous-mobile-robot\",\n   104\t      \"robot-maintenance-diagnostics\",\n   105\t      \"digital-twin-simulation\",\n   106\t    ];\n   107\t    this.expectedRoles = [\"operator\", \"engineer\", \"developer\"];\n   108\t    this.expectedSkillTypes = [\"knowledge\", \"skill\", \"competence\"];\n   109\t  }\n   110\t\n   111\t  // 테스트 1: 파일 존재 및 접근성\n   112\t  testFileExistence() {\n   113\t    testSection(\"테스트 1: 파일 존재 및 접근성\");\n   114\t\n   115\t    const files = [\n   116\t      \"public/data/robot-smartfactory.json\",\n   117\t      \"docs/SMARTFACTORY_SKILL_DESIGN.md\",\n   118\t      \"scripts/generate-robot-smartfactory-data.py\",\n   119\t      \"scripts/validate-robot-data.js\",\n   120\t      \"scripts/test-robot-smartfactory.js\",\n   121\t    ];\n   122\t\n   123\t    files.forEach((file) => {\n   124\t      const filePath = path.join(process.cwd(), file);\n   125\t      const exists = fs.existsSync(filePath);\n   126\t      assert(exists, `파일 존재: ${file}`);\n   127\t    });\n   128\t  }\n   129\t\n   130\t  // 테스트 2: JSON 로드 및 기본 구조\n   131\t  testJsonLoading() {\n   132\t    testSection(\"테스트 2: JSON 로드 및 기본 구조\");\n   133\t\n   134\t    try {\n   135\t      const dataPath = path.join(\n   136\t        process.cwd(),\n   137\t        \"public/data/robot-smartfactory.json\",\n   138\t      );\n   139\t      const content = fs.readFileSync(dataPath, \"utf-8\");\n   140\t      this.skillData = JSON.parse(content);\n   141\t      assert(Array.isArray(this.skillData), \"JSON은 배열 형식이어야 함\");\n   142\t      assert(this.skillData.length > 0, \"JSON에 최소 1개 이상의 스킬 포함\");\n   143\t    } catch (error) {\n   144\t      assert(false, `JSON 파일 로드 실패: ${error.message}`);\n   145\t      throw error;\n   146\t    }\n   147\t  }\n   148\t\n   149\t  // 테스트 3: 데이터 스키마 검증\n   150\t  testDataSchema() {\n   151\t    testSection(\"테스트 3: 데이터 스키마 검증\");\n   152\t\n   153\t    const requiredFields = [\n   154\t      \"skill_id\",\n   155\t      \"domain\",\n   156\t      \"domain_en\",\n   157\t      \"esco_uri\",\n   158\t      \"preferred_label_ko\",\n   159\t      \"preferred_label_en\",\n   160\t      \"description_ko\",\n   161\t      \"description_en\",\n   162\t      \"skill_type\",\n   163\t      \"proficiency_level\",\n   164\t      \"role_mapping\",\n   165\t    ];\n   166\t\n   167\t    let schemaErrors = 0;\n   168\t    this.skillData.forEach((skill, index) => {\n   169\t      requiredFields.forEach((field) => {\n   170\t        if (!(field in skill) || skill[field] === null || skill[field] === \"\") {\n   171\t          schemaErrors++;\n   172\t          if (schemaErrors <= 3) {\n   173\t            // 처음 3개 에러만 표시\n   174\t            assert(\n   175\t              false,\n   176\t              `스킬 #${index} (${skill.skill_id}): 필수 필드 '${field}' 누락`,\n   177\t            );\n   178\t          }\n   179\t        }\n   180\t      });\n   181\t    });\n   182\t\n   183\t    if (schemaErrors === 0) {\n   184\t      assert(\n   185\t        true,\n   186\t        `모든 스킬이 필수 필드를 포함 (검사: ${this.skillData.length}개)`,\n   187\t      );\n   188\t    } else if (schemaErrors > 3) {\n   189\t      assert(false, `추가 ${schemaErrors - 3}개의 스키마 오류 발견`);\n   190\t    }\n   191\t  }\n   192\t\n   193\t  // 테스트 4: 도메인 검증\n   194\t  testDomains() {\n   195\t    testSection(\"테스트 4: 도메인 검증\");\n   196\t\n   197\t    const domainStats = {};\n   198\t    this.skillData.forEach((skill) => {\n   199\t      if (!domainStats[skill.domain]) {\n   200\t        domainStats[skill.domain] = 0;\n   201\t      }\n   202\t      domainStats[skill.domain]++;\n   203\t    });\n   204\t\n   205\t    // 모든 예상 도메인 존재 확인\n   206\t    this.expectedDomains.forEach((domain) => {\n   207\t      const exists = domain in domainStats;\n   208\t      assert(exists, `도메인 존재: ${domain}`);\n   209\t    });\n   210\t\n   211\t    // 도메인별 스킬 수 확인\n   212\t    this.expectedDomains.forEach((domain) => {\n   213\t      const count = domainStats[domain] || 0;\n   214\t      assert(\n   215\t        count >= 20,\n   216\t        `도메인 '${domain}': 최소 20개 이상의 스킬 (현재: ${count}개)`,\n   217\t      );\n   218\t    });\n   219\t  }\n   220\t\n   221\t  // 테스트 5: 역할 매핑 검증\n   222\t  testRoleMapping() {\n   223\t    testSection(\"테스트 5: 역할 매핑 검증\");\n   224\t\n   225\t    const roleStats = {};\n   226\t    this.expectedRoles.forEach((role) => {\n   227\t      roleStats[role] = 0;\n   228\t    });\n   229\t\n   230\t    this.skillData.forEach((skill) => {\n   231\t      if (!Array.isArray(skill.role_mapping)) {\n   232\t        assert(false, `스킬 ${skill.skill_id}: role_mapping은 배열이어야 함`);\n   233\t        return;\n   234\t      }\n   235\t\n   236\t      skill.role_mapping.forEach((role) => {\n   237\t        if (role in roleStats) {\n   238\t          roleStats[role]++;\n   239\t        }\n   240\t      });\n   241\t    });\n   242\t\n   243\t    // 모든 역할 포함 확인\n   244\t    this.expectedRoles.forEach((role) => {\n   245\t      const count = roleStats[role];\n   246\t      assert(count > 0, `역할 '${role}' 포함됨 (${count}개 스킬)`);\n   247\t    });\n   248\t  }\n   249\t\n   250\t  // 테스트 6: 숙련도 레벨 검증\n   251\t  testProficiencyLevels() {\n   252\t    testSection(\"테스트 6: 숙련도 레벨 검증\");\n   253\t\n   254\t    const levelStats = { 1: 0, 2: 0, 3: 0, 4: 0 };\n   255\t    let invalidLevels = 0;\n   256\t\n   257\t    this.skillData.forEach((skill) => {\n   258\t      const level = skill.proficiency_level;\n   259\t      if (level >= 1 && level <= 4) {\n   260\t        levelStats[level]++;\n   261\t      } else {\n   262\t        invalidLevels++;\n   263\t      }\n   264\t    });\n   265\t\n   266\t    assert(invalidLevels === 0, `모든 proficiency_level이 1~4 범위 내`);\n   267\t\n   268\t    // 모든 레벨이 표현되는지 확인\n   269\t    for (let level = 1; level <= 4; level++) {\n   270\t      const count = levelStats[level];\n   271\t      assert(count > 0, `Level ${level} 존재 (${count}개 스킬)`);\n   272\t    }\n   273\t  }\n   274\t\n   275\t  // 테스트 7: 스킬 타입 검증\n   276\t  testSkillTypes() {\n   277\t    testSection(\"테스트 7: 스킬 타입 검증\");\n   278\t\n   279\t    const typeStats = {};\n   280\t    this.expectedSkillTypes.forEach((type) => {\n   281\t      typeStats[type] = 0;\n   282\t    });\n   283\t\n   284\t    this.skillData.forEach((skill) => {\n   285\t      if (skill.skill_type in typeStats) {\n   286\t        typeStats[skill.skill_type]++;\n   287\t      }\n   288\t    });\n   289\t\n   290\t    // 모든 타입이 표현되는지 확인\n   291\t    this.expectedSkillTypes.forEach((type) => {\n   292\t      const count = typeStats[type];\n   293\t      assert(count > 0, `스킬 타입 '${type}' 존재 (${count}개)`);\n   294\t    });\n   295\t\n   296\t    // 3층 계층 구조 비율 확인\n   297\t    const totalCount = this.skillData.length;\n   298\t    const knowledgeRatio = (\n   299\t      (typeStats[\"knowledge\"] / totalCount) *\n   300\t      100\n   301\t    ).toFixed(1);\n   302\t    const skillRatio = ((typeStats[\"skill\"] / totalCount) * 100).toFixed(1);\n   303\t    const competenceRatio = (\n   304\t      (typeStats[\"competence\"] / totalCount) *\n   305\t      100\n   306\t    ).toFixed(1);\n   307\t\n   308\t    assert(\n   309\t      typeStats[\"knowledge\"] > 0 &&\n   310\t        typeStats[\"skill\"] > 0 &&\n   311\t        typeStats[\"competence\"] > 0,\n   312\t      `계층 구조 균형: Knowledge ${knowledgeRatio}%, Skill ${skillRatio}%, Competence ${competenceRatio}%`,\n   313\t    );\n   314\t  }\n   315\t\n   316\t  // 테스트 8: 한영 데이터 완성도\n   317\t  testBilingualData() {\n   318\t    testSection(\"테스트 8: 한영 데이터 완성도\");\n   319\t\n   320\t    let missingKorean = 0;\n   321\t    let missingEnglish = 0;\n   322\t\n   323\t    this.skillData.forEach((skill, index) => {\n   324\t      if (!skill.preferred_label_ko || skill.preferred_label_ko.trim() === \"\") {\n   325\t        if (missingKorean <= 2) {\n   326\t          assert(false, `스킬 #${index}: 한글 레이블 누락`);\n   327\t        }\n   328\t        missingKorean++;\n   329\t      }\n   330\t\n   331\t      if (!skill.preferred_label_en || skill.preferred_label_en.trim() === \"\") {\n   332\t        if (missingEnglish <= 2) {\n   333\t          assert(false, `스킬 #${index}: 영문 레이블 누락`);\n   334\t        }\n   335\t        missingEnglish++;\n   336\t      }\n   337\t\n   338\t      if (!skill.description_ko || skill.description_ko.trim() === \"\") {\n   339\t        if (missingKorean <= 2) {\n   340\t          assert(false, `스킬 #${index}: 한글 설명 누락`);\n   341\t        }\n   342\t      }\n   343\t\n   344\t      if (!skill.description_en || skill.description_en.trim() === \"\") {\n   345\t        if (missingEnglish <= 2) {\n   346\t          assert(false, `스킬 #${index}: 영문 설명 누락`);\n   347\t        }\n   348\t      }\n   349\t    });\n   350\t\n   351\t    if (missingKorean === 0 && missingEnglish === 0) {\n   352\t      assert(true, `모든 스킬의 한영 데이터 완성`);\n   353\t    }\n   354\t  }\n   355\t\n   356\t  // 테스트 9: ESCO URI 형식 검증\n   357\t  testEscoUri() {\n   358\t    testSection(\"테스트 9: ESCO URI 형식 검증\");\n   359\t\n   360\t    let validCount = 0;\n   361\t    let invalidCount = 0;\n   362\t\n   363\t    this.skillData.forEach((skill) => {\n   364\t      const uri = skill.esco_uri;\n   365\t      // ESCO URI는 http://data.europa.eu/esco/skill/ 형식이거나\n   366\t      // rsf로 시작하는 커스텀 형식\n   367\t      if (\n   368\t        uri.startsWith(\"http://data.europa.eu/esco/skill/\") ||\n   369\t        uri.includes(\"rsf\")\n   370\t      ) {\n   371\t        validCount++;\n   372\t      } else {\n   373\t        invalidCount++;\n   374\t        if (invalidCount <= 3) {\n   375\t          assert(\n   376\t            false,\n   377\t            `스킬 ${skill.skill_id}: 유효하지 않은 ESCO URI 형식 (${uri})`,\n   378\t          );\n   379\t        }\n   380\t      }\n   381\t    });\n   382\t\n   383\t    if (invalidCount === 0) {\n   384\t      assert(true, `모든 ESCO URI가 유효한 형식 (총 ${validCount}개)`);\n   385\t    } else if (invalidCount > 3) {\n   386\t      assert(false, `추가 ${invalidCount - 3}개의 URI 형식 오류`);\n   387\t    }\n   388\t  }\n   389\t\n   390\t  // 테스트 10: 스킬 ID 형식 검증\n   391\t  testSkillIdFormat() {\n   392\t    testSection(\"테스트 10: 스킬 ID 형식 검증\");\n   393\t\n   394\t    const skillIdRegex = /^RSF-[A-Z]+(-\\d{3})$/;\n   395\t    let validCount = 0;\n   396\t    let invalidCount = 0;\n   397\t\n   398\t    this.skillData.forEach((skill) => {\n   399\t      if (skillIdRegex.test(skill.skill_id)) {\n   400\t        validCount++;\n   401\t      } else {\n   402\t        invalidCount++;\n   403\t        if (invalidCount <= 3) {\n   404\t          assert(false, `유효하지 않은 스킬 ID 형식: ${skill.skill_id}`);\n   405\t        }\n   406\t      }\n   407\t    });\n   408\t\n   409\t    if (invalidCount === 0) {\n   410\t      assert(\n   411\t        true,\n   412\t        `모든 스킬 ID가 'RSF-[CODE]-[NUMBER]' 형식 (총 ${validCount}개)`,\n   413\t      );\n   414\t    }\n   415\t  }\n   416\t\n   417\t  // 테스트 11: 스마트팩토리 컨텍스트 검증\n   418\t  testSmartFactoryContext() {\n   419\t    testSection(\"테스트 11: 스마트팩토리 컨텍스트 검증\");\n   420\t\n   421\t    let contextCount = 0;\n   422\t    let missingCount = 0;\n   423\t\n   424\t    this.skillData.forEach((skill) => {\n   425\t      if (\n   426\t        skill.smartfactory_context &&\n   427\t        skill.smartfactory_context.trim() !== \"\"\n   428\t      ) {\n   429\t        contextCount++;\n   430\t      } else {\n   431\t        missingCount++;\n   432\t      }\n   433\t    });\n   434\t\n   435\t    const contextRatio = ((contextCount / this.skillData.length) * 100).toFixed(\n   436\t      1,\n   437\t    );\n   438\t    assert(\n   439\t      contextCount > 0,\n   440\t      `스마트팩토리 컨텍스트 포함: ${contextRatio}% (${contextCount}개 스킬)`,\n   441\t    );\n   442\t\n   443\t    if (missingCount > 0) {\n   444\t      assert(false, `컨텍스트 누락: ${missingCount}개 스킬`);\n   445\t    }\n   446\t  }\n   447\t\n   448\t  // 테스트 12: 부모-자식 관계 무결성\n   449\t  testParentChildRelationship() {\n   450\t    testSection(\"테스트 12: 부모-자식 관계 무결성\");\n   451\t\n   452\t    const skillIds = new Set(this.skillData.map((s) => s.skill_id));\n   453\t    let validParents = 0;\n   454\t    let orphans = 0;\n   455\t\n   456\t    this.skillData.forEach((skill) => {\n   457\t      if (skill.parent_skill_id) {\n   458\t        if (skillIds.has(skill.parent_skill_id)) {\n   459\t          validParents++;\n   460\t        } else {\n   461\t          orphans++;\n   462\t          if (orphans <= 3) {\n   463\t            assert(\n   464\t              false,\n   465\t              `고아 스킬: ${skill.skill_id} (부모: ${skill.parent_skill_id} 없음)`,\n   466\t            );\n   467\t          }\n   468\t        }\n   469\t      }\n   470\t    });\n   471\t\n   472\t    if (orphans === 0) {\n   473\t      assert(true, `모든 부모-자식 관계가 유효 (부모 관계: ${validParents}개)`);\n   474\t    }\n   475\t  }\n   476\t\n   477\t  // 테스트 13: 전체 스킬 수 목표 달성\n   478\t  testSkillCountTarget() {\n   479\t    testSection(\"테스트 13: 전체 스킬 수 목표 달성\");\n   480\t\n   481\t    const minTarget = 120;\n   482\t    const actualCount = this.skillData.length;\n   483\t    const achievementRatio = ((actualCount / minTarget) * 100).toFixed(1);\n   484\t\n   485\t    assert(\n   486\t      actualCount >= minTarget,\n   487\t      `스킬 수 목표 달성: ${actualCount}개 (목표: ${minTarget}개 이상, 달성률: ${achievementRatio}%)`,\n   488\t    );\n   489\t  }\n   490\t\n   491\t  // 테스트 14: 도메인별 균형 검증\n   492\t  testDomainBalance() {\n   493\t    testSection(\"테스트 14: 도메인별 균형 검증\");\n   494\t\n   495\t    const domainStats = {};\n   496\t    this.skillData.forEach((skill) => {\n   497\t      domainStats[skill.domain] = (domainStats[skill.domain] || 0) + 1;\n   498\t    });\n   499\t\n   500\t    const counts = Object.values(domainStats);\n   501\t    const minCount = Math.min(...counts);\n   502\t    const maxCount = Math.max(...counts);\n   503\t    const avgCount = (\n   504\t      counts.reduce((a, b) => a + b, 0) / counts.length\n   505\t    ).toFixed(1);\n   506\t\n   507\t    const isBalanced = maxCount - minCount <= 2;\n   508\t    assert(\n   509\t      isBalanced,\n   510\t      `도메인 균형: 최소 ${minCount}개, 최대 ${maxCount}개, 평균 ${avgCount}개 (편차 ${maxCount - minCount}개)`,\n   511\t    );\n   512\t  }\n   513\t\n   514\t  // 테스트 15: 설계 문서 존재 및 일관성\n   515\t  testDesignDocConsistency() {\n   516\t    testSection(\"테스트 15: 설계 문서 존재 및 일관성\");\n   517\t\n   518\t    try {\n   519\t      const docPath = path.join(\n   520\t        process.cwd(),\n   521\t        \"docs/SMARTFACTORY_SKILL_DESIGN.md\",\n   522\t      );\n   523\t      const docContent = fs.readFileSync(docPath, \"utf-8\");\n   524\t      this.designDoc = docContent;\n   525\t\n   526\t      // 설계 문서에 모든 도메인이 명시되어 있는지 확인 (영문명 기반)\n   527\t      const domainKeywords = [\n   528\t        \"Industrial Robot Control\",\n   529\t        \"Machine Vision\",\n   530\t        \"Collaborative Robot\",\n   531\t        \"AMR/AGV\",\n   532\t        \"Maintenance & Diagnostics\",\n   533\t        \"Digital Twin\",\n   534\t      ];\n   535\t\n   536\t      let allDomainsInDoc = true;\n   537\t      domainKeywords.forEach((keyword) => {\n   538\t        if (!docContent.includes(keyword)) {\n   539\t          allDomainsInDoc = false;\n   540\t        }\n   541\t      });\n   542\t\n   543\t      assert(allDomainsInDoc, \"설계 문서에 모든 6개 도메인이 포함됨\");\n   544\t      assert(\n   545\t        docContent.includes(\"3층\") ||\n   546\t          docContent.includes(\"Knowledge\") ||\n   547\t          docContent.includes(\"Competence\"),\n   548\t        \"설계 문서에 3층 계층 구조 설명 포함\",\n   549\t      );\n   550\t      assert(\n   551\t        docContent.includes(\"Operator\") || docContent.includes(\"operator\"),\n   552\t        \"설계 문서에 역할 정의 포함\",\n   553\t      );\n   554\t    } catch (error) {\n   555\t      assert(false, `설계 문서 읽기 실패: ${error.message}`);\n   556\t    }\n   557\t  }\n   558\t\n   559\t  // 전체 테스트 실행\n   560\t  runAll() {\n","tool_use_id":"call_RCb3pYDKdWctthL8kdVIrvcn"}
