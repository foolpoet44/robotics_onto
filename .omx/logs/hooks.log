es/react\": \"^18.0.15\",\n    23\t    \"typescript\": \"^5.9.3\"\n    24\t  }\n    25\t}\n\nTASK CARD P3\n   198\t## P3-1 · 관계 실질 검사\n   199\t\n   200\t- **문제**: 검증기가 빈 관계망에 초록불(거짓 안심).\n   201\t- **근거**: 진단 F-5.\n   202\t- **목표**: 비어 있으면 **실패**. 고립 노드 0, 양방향 대칭 권장 점검.\n   203\t- **손댈 파일**: `scripts/validate-robot-data.js`.\n   204\t- **구현 지침**: related_skills 커버리지 임계값(예: 평균 ≥ 2, 고립 0)을 `errors`로 승격.\n   205\t  A→B면 B→A 누락 시 `warnings`.\n   206\t- **DoD**:\n   207\t  - 일부러 빈 배열로 만든 픽스처에서 검증기가 **비정상 종료(exit ≠ 0)**.\n   208\t  - 정상 데이터에서 `$ npm run validate:data` → 통과.\n   209\t\n   210\t---\n   211\t\n   212\t## P3-2 · URI 진위/네임스페이스 검사\n   213\t\n   214\t- **문제**: `esco_uri`를 존재만 검사, 진위 미검사.\n   215\t- **근거**: 진단 F-5, F-2.\n   216\t- **목표**: ESCO 네임스페이스 + 가짜 슬러그 조합이면 실패. 내부 URN 규칙 검사.\n   217\t- **손댈 파일**: `scripts/validate-robot-data.js`.\n   218\t- **구현 지침**: 스펙 §4의 규칙을 검사로 코드화.\n   219\t- **DoD**:\n   220\t  - 가짜 `rsf-` ESCO URI 픽스처에서 검증기 exit ≠ 0.\n   221\t  - `$ npm run validate:data` → 통과(정직화된 데이터에서).\n   222\t\n   223\t---\n   224\t\n   225\t## P3-3 · 사이클·일관성 검사\n   226\t\n   227\t- **문제**: `parent_skill_id` 순환·enum 일관성 미점검.\n   228\t- **근거**: 진단 F-5(확장).\n   229\t- **목표**: 부모 체인 순환 탐지, 역할/숙련도/타입 enum 검증.\n   230\t- **손댈 파일**: `scripts/validate-robot-data.js`.\n   231\t- **DoD**:\n   232\t  - 순환을 심은 픽스처에서 exit ≠ 0. 정상 데이터 통과.\n   233\t\n   234\t---\n   235\t\n   236\t## P3-4 · 게이트 연결 (pre-commit / CI)\n   237\t\n   238\t- **문제**: 검증/타입체크가 사람 기억에 의존.\n   239\t- **근거**: 진단 F-5, 불변식.\n   240\t- **목표**: `type-check` + `validate:data` + `build`를 자동 게이트로 묶음.\n   241\t- **손댈 파일**: `.husky/`(또는 간단한 git hook), 그리고/또는 `.github/workflows/ci.yml`.\n   242\t- **구현 지침**: pre-commit에서 `type-check`+`validate:data`, CI에서 3종 모두.\n   243\t- **DoD**:\n   244\t  - 게이트가 실패하면 커밋/머지가 막힌다(로컬 훅 또는 CI 로그로 확인).\n   245\t\n   246\t---\n\nSPEC RULES\n   105\t## 5. 데이터 계약 (요약)\n   106\t\n   107\t```ts\n   108\texport interface RobotSkill {\n   109\t  skill_id: string;                  // 내부 PK, 데이터 내 유일\n   110\t  domain: string;                    // ROBOT_DOMAINS.key 중 하나\n   111\t  domain_en: string;\n   112\t  preferred_label_ko: string;\n   113\t  preferred_label_en: string;\n   114\t  description_ko: string;\n   115\t  description_en: string;\n   116\t  skill_type: \"knowledge\" | \"skill\" | \"competence\";\n   117\t  proficiency_level: 1 | 2 | 3 | 4;\n   118\t  role_mapping: (\"operator\" | \"engineer\" | \"developer\")[];\n   119\t  parent_skill_id: string | null;    // 존재하는 skill_id 또는 null (순환 금지)\n   120\t  related_skills: SkillRelation[];   // §2.2 — 비어 있으면 P3-1 실패\n   121\t  // 출처(§4): 옵션 A 또는 B 중 택일하여 구현\n   122\t  internal_uri?: string;             // 옵션 B\n   123\t  esco_uri: string | null;           // 실재 ESCO 매핑일 때만 채움\n   124\t  esco_mapping?: { uri: string | null; confidence: string; matched_label?: string }; // 옵션 A\n   125\t  smartfactory_context: string;\n   126\t}\n   127\t```\n   128\t\n   129\t## 6. 불변(데이터 무결성 규칙) — P3 검증으로 강제\n   130\t\n   131\t- 모든 `parent_skill_id`·`related_skills[].target`은 존재하는 `skill_id`여야 한다(dangling 0).\n   132\t- `parent_skill_id` 체인에 순환이 없어야 한다.\n   133\t- 고립 노드(관계 0개) 0, 스킬당 평균 관계 ≥ 2, 스킬당 관계 ≤ 8.\n   134\t- `esco_uri`가 `data.europa.eu/esco`를 포함하면 가짜 슬러그(`rsf-`) 금지 — 실재 UUID만 허용.\n   135\t- enum(`skill_type`/`role_mapping`/`proficiency_level`) 값은 계약 범위 내.\n\nCURRENT METRICS\nskills 127\nedges 0\nisolated 127\nfake_esco 127\n","tool_use_id":"call_nR38q1Pwk6slbUwEhGm1EDqO"}
