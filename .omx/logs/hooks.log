      \"enabler_name\": \"로봇 솔루션 표준 패키지화\",\n      \"organization_skill\": {\n        \"skill_id\": \"RS_025\",\n        \"label_ko\": \"OpenCV / Halcon\"\n      },\n      \"ontology_skill\": {\n        \"skill_id\": \"RSF-MVS-004\",\n        \"label_ko\": \"컴퓨터 비전 알고리즘\",\n        \"domain\": \"machine-vision-sensor\"\n      }\n    },\n    {\n      \"id\": \"organization_mapping:robot_solution:RS_035\",\n      \"kind\": \"organization_mapping\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"organization_id\": \"robot_solution\",\n      \"organization_name\": \"로봇솔루션 Task\",\n      \"enabler_name\": \"IRIS 기반 AI 기술 적용\",\n      \"organization_skill\": {\n        \"skill_id\": \"RS_035\",\n        \"label_ko\": \"이상 탐지 알고리즘\"\n      },\n      \"ontology_skill\": {\n        \"skill_id\": \"RSF-MVS-007\",\n        \"label_ko\": \"이미지 기반 결함 검출\",\n        \"domain\": \"machine-vision-sensor\"\n      }\n    },\n    {\n      \"id\": \"organization_mapping:robot_solution:RS_036\",\n      \"kind\": \"organization_mapping\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"organization_id\": \"robot_solution\",\n      \"organization_name\": \"로봇솔루션 Task\",\n      \"enabler_name\": \"IRIS 기반 AI 기술 적용\",\n      \"organization_skill\": {\n        \"skill_id\": \"RS_036\",\n        \"label_ko\": \"시계열 데이터 분석\"\n      },\n      \"ontology_skill\": {\n        \"skill_id\": \"RSF-RMD-007\",\n        \"label_ko\": \"트렌드 분석\",\n        \"domain\": \"robot-maintenance-diagnostics\"\n      }\n    },\n    {\n      \"id\": \"organization_mapping:robot_solution:RS_039\",\n      \"kind\": \"organization_mapping\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"organization_id\": \"robot_solution\",\n      \"organization_name\": \"로봇솔루션 Task\",\n      \"enabler_name\": \"IRIS 기반 AI 기술 적용\",\n      \"organization_skill\": {\n        \"skill_id\": \"RS_039\",\n        \"label_ko\": \"객체 검출 AI\"\n      },\n      \"ontology_skill\": {\n        \"skill_id\": \"RSF-MVS-007\",\n        \"label_ko\": \"이미지 기반 결함 검출\",\n        \"domain\": \"machine-vision-sensor\"\n      }\n    },\n    {\n      \"id\": \"organization_mapping:robot_solution:RS_042\",\n      \"kind\": \"organization_mapping\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"organization_id\": \"robot_solution\",\n      \"organization_name\": \"로봇솔루션 Task\",\n      \"enabler_name\": \"IRIS 기반 AI 기술 적용\",\n      \"organization_skill\": {\n        \"skill_id\": \"RS_042\",\n        \"label_ko\": \"실시간 데이터 처리\"\n      },\n      \"ontology_skill\": {\n        \"skill_id\": \"RSF-DTS-005\",\n        \"label_ko\": \"실시간 데이터 파이프라인\",\n        \"domain\": \"digital-twin-simulation\"\n      }\n    },\n    {\n      \"id\": \"ontology_relation:cross_domain:RSF-AMR-001:RSF-CRO-001\",\n      \"kind\": \"ontology_relation\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"relation_type\": \"cross_domain\",\n      \"source_skill\": {\n        \"skill_id\": \"RSF-CRO-001\",\n        \"label_ko\": \"협동로봇 안전 개념\",\n        \"domain\": \"collaborative-robot\"\n      },\n      \"target_skill\": {\n        \"skill_id\": \"RSF-AMR-001\",\n        \"label_ko\": \"SLAM 개념\",\n        \"domain\": \"autonomous-mobile-robot\"\n      }\n    },\n    {\n      \"id\": \"ontology_relation:cross_domain:RSF-AMR-001:RSF-RMD-001\",\n      \"kind\": \"ontology_relation\",\n      \"priority\": \"high\",\n      \"status\": \"pending\",\n      \"relation_type\": \"cross_domain\",\n      \"source_skill\": {\n        \"skill_id\": \"RSF-AMR-001\",\n        \"label_ko\": \"SLAM 개념\",\n        \"domain\": \"autonomous-mobile-robot\"\n","tool_use_id":"call_vLVpdF2zOPS2GLh2qdiElIRB"}
2026-06-03T00:45:33.260Z PostToolUse status=unknown {"session_id":"019e8aef-3179-71d1-b4c4-e42922f1a896","turn_id":"019e8aef-320b-7170-a04d-79f219de3434","transcript_path":null,"cwd":"/Users/dkmac/Desktop/@26/factory-robotics-skillmap","hook_event_name":"PostToolUse","model":"gpt-5.4","permission_mode":"bypassPermissions","tool_name":"Bash","tool_input":{"command":"sed -n '1,220p' app/reviews/page.tsx && printf '\\n---\\n' && sed -n '1,220p' app/development-tracks/[trackId]/candidates/[candidateId]/page.tsx && printf '\\n---\\n' && sed -n '1,220p' app/components/SkillImportanceRating.tsx"},"tool_response":"import Link from \"next/link\";\nimport { ReviewItem } from \"../lib/review-data\";\nimport { getReviewQueue } from \"../lib/server-data\";\nimport styles from \"./page.module.css\";\n\nconst RELATION_LABELS = {\n  prerequisite: \"선행 관계\",\n  co_required: \"동반 관계\",\n  specialization: \"특화 관계\",\n  cross_domain: \"도메인 연결\",\n};\n\nconst BIDIRECTIONAL_RELATIONS = new Set([\"co_required\", \"cross_domain\"]);\nconst STATUS_LABELS = {\n  pending: \"검수 대기\",\n  approved: \"승인\",\n  held: \"보류\",\n  rejected: \"반려\",\n};\n\nfunction SkillLink({\n  skill,\n}: {\n  skill: { skill_id: string; label_ko: string; domain: string };\n}) {\n  return (\n    <Link href={`/skills/${skill.skill_id}`}>\n      {skill.label_ko}\n      <small>{skill.skill_id}</small>\n    </Link>\n  );\n}\n\nfunction ReviewCard({ item }: { item: ReviewItem }) {\n  if (item.kind === \"organization_mapping\") {\n    return (\n      <article className={styles.reviewCard}>\n        <header>\n          <span className={styles.highPriority}>우선 검수</span>\n          <span>조직 역량 매핑</span>\n          <span className={styles[item.status]}>{STATUS_LABELS[item.status]}</span>\n        </header>\n        <h2>{item.organization_skill.label_ko}</h2>\n        <p>\n          {item.organization_name} · {item.enabler_name}\n        </p>\n        <div className={styles.mapping}>\n          <strong>{item.organization_skill.skill_id}</strong>\n          <span>→</span>\n          <SkillLink skill={item.ontology_skill} />\n        </div>\n        <p className={styles.question}>\n          두 역량을 같은 기준 스킬로 연결해도 되는지 확인해 주세요.\n        </p>\n        {item.decision && (\n          <p className={styles.decision}>\n            {item.decision.reviewer} · {item.decision.reviewed_at}\n          </p>\n        )}\n      </article>\n    );\n  }\n\n  return (\n    <article className={styles.reviewCard}>\n      <header>\n        <span className={styles[item.priority]}>관계 후보</span>\n        <span>{RELATION_LABELS[item.relation_type]}</span>\n        <span className={styles[item.status]}>{STATUS_LABELS[item.status]}</span>\n      </header>\n      <div className={styles.mapping}>\n        <SkillLink skill={item.source_skill} />\n        <span>\n          {BIDIRECTIONAL_RELATIONS.has(item.relation_type) ? \"↔\" : \"→\"}\n        </span>\n        <SkillLink skill={item.target_skill} />\n      </div>\n      <p className={styles.question}>\n        현장 역량 관점에서 이 연결이 유효한지 확인해 주세요.\n      </p>\n      {item.decision && (\n        <p className={styles.decision}>\n          {item.decision.reviewer} · {item.decision.reviewed_at}\n        </p>\n      )}\n    </article>\n  );\n}\n\nexport default async function ReviewsPage() {\n  const queue = await getReviewQueue();\n  const highPriorityItems = queue.items.filter(\n    (item) => item.status === \"pending\" && item.priority === \"high\",\n  );\n  const normalItems = queue.items.filter(\n    (item) => item.status === \"pending\" && item.priority === \"normal\",\n  );\n  const recordedItems = queue.items.filter((item) => item.status !== \"pending\");\n\n  return (\n    <main className={styles.pageShell}>\n      <header className={styles.pageHeading}>\n        <p>EXPERT REVIEW QUEUE</p>\n        <h1>현장 전문가 검수 큐</h1>\n        <span>\n          자동 생성된 후보입니다. 연결을 확정하기 전에 HR·현장 전문가의 판단이\n          필요합니다.\n        </span>\n      </header>\n\n      <section className={styles.summaryGrid} aria-label=\"검수 큐 요약\">\n        <div>\n          <strong>{queue.stats.total}</strong>\n          <span>전체 후보</span>\n        </div>\n        <div>\n          <strong>{queue.stats.organizationMappings}</strong>\n          <span>조직 근사 매핑</span>\n        </div>\n        <div>\n          <strong>{queue.stats.ontologyRelations}</strong>\n          <span>온톨로지 관계</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.pending}</strong>\n          <span>검수 대기</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.approved}</strong>\n          <span>승인</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.held}</strong>\n          <span>보류</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.rejected}</strong>\n          <span>반려</span>\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>우선 검수</h2>\n        <p>근사 매핑과 도메인 간 연결처럼 판단 영향이 큰 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {highPriorityItems.length === 0 ? (\n            <p>우선 검수 대기 항목이 없습니다.</p>\n          ) : (\n            highPriorityItems.map((item) => (\n              <ReviewCard item={item} key={item.id} />\n            ))\n          )}\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>일반 검수</h2>\n        <p>같은 도메인 안에서 자동 생성된 관계 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {normalItems.map((item) => (\n            <ReviewCard item={item} key={item.id} />\n          ))}\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>검수 기록</h2>\n        <p>승인·보류·반려가 기록된 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {recordedItems.length === 0 ? (\n            <p>아직 기록된 검수 결과가 없습니다.</p>\n          ) : (\n            recordedItems.map((item) => (\n              <ReviewCard item={item} key={item.id} />\n            ))\n          )}\n        </div>\n      </section>\n    </main>\n  );\n}\n\n---\nzsh:1: no matches found: app/development-tracks/[trackId]/candidates/[candidateId]/page.tsx\n","tool_use_id":"call_IL8CMfvlB9T20wFGXtmfWMFz"}
2026-06-03T00:45:37.218Z PostToolUse status=unknown {"session_id":"019e8aef-3179-71d1-b4c4-e42922f1a896","turn_id":"019e8aef-320b-7170-a04d-79f219de3434","transcript_path":null,"cwd":"/Users/dkmac/Desktop/@26/factory-robotics-skillmap","hook_event_name":"PostToolUse","model":"gpt-5.4","permission_mode":"bypassPermissions","tool_name":"Bash","tool_input":{"command":"sed -n '1,220p' 'app/development-tracks/[trackId]/candidates/[candidateId]/page.tsx' && printf '\\n---\\n' && sed -n '1,220p' app/components/SkillImportanceRating.tsx"},"tool_response":"import Link from \"next/link\";\nimport { notFound } from \"next/navigation\";\nimport {\n  DevelopmentStageStatus,\n  getExpertArea,\n  getNextStage,\n  getStage,\n} from \"../../../../lib/development-data\";\nimport {\n  getAllRobotSkills,\n  getDevelopmentCandidate,\n  getDevelopmentCandidates,\n  getDevelopmentTrack,\n  getDevelopmentTrackIds,\n} from \"../../../../lib/server-data\";\nimport styles from \"./page.module.css\";\n\nconst STATUS_LABELS: Record<DevelopmentStageStatus, string> = {\n  pending: \"대기\",\n  in_progress: \"진행 중\",\n  completed: \"완료\",\n  held: \"보류\",\n};\n\nconst IMPACT_STATUS_LABELS = {\n  draft: \"초안\",\n  approved: \"승인\",\n  delivered: \"현장 적용\",\n};\n\nexport async function generateStaticParams() {\n  const params = await Promise.all(\n    getDevelopmentTrackIds().map(async (trackId) => {\n      const candidates = await getDevelopmentCandidates(trackId);\n      return candidates.map((candidate) => ({\n        trackId,\n        candidateId: candidate.candidate_id,\n      }));\n    }),\n  );\n  return params.flat();\n}\n\nexport default async function CandidateDevelopmentPage({\n  params,\n}: {\n  params: Promise<{ trackId: string; candidateId: string }>;\n}) {\n  const { trackId, candidateId } = await params;\n  const [track, candidate, skills] = await Promise.all([\n    getDevelopmentTrack(trackId),\n    getDevelopmentCandidate(trackId, candidateId),\n    getAllRobotSkills(),\n  ]);\n  if (!track || !candidate) {\n    notFound();\n  }\n\n  const skillsById = new Map(skills.map((skill) => [skill.skill_id, skill]));\n  const expertArea = getExpertArea(track, candidate.expert_area_profile_id);\n  const currentStage = getStage(track, candidate.current_stage_id);\n  const nextStage = getNextStage(track, candidate.current_stage_id);\n\n  return (\n    <main className={styles.pageShell}>\n      <Link className={styles.backLink} href=\"/development-tracks\">\n        ← 육성 트랙\n      </Link>\n      <header className={styles.hero}>\n        <div>\n          <p>CANDIDATE DEVELOPMENT CARD</p>\n          <h1>{candidate.display_name}</h1>\n          <span>{candidate.candidate_id} · {track.cohort}</span>\n        </div>\n        <div className={styles.currentStage}>\n          <small>현재 단계</small>\n          <strong>{currentStage?.name}</strong>\n          <span>{expertArea?.name}</span>\n        </div>\n      </header>\n\n      <section className={styles.section}>\n        <h2>단계별 육성 여정</h2>\n        <div className={styles.journey}>\n          {track.stages.map((stage) => {\n            const history = candidate.stage_history.find(\n              (item) => item.stage_id === stage.id,\n            );\n            const status = history?.status ?? \"pending\";\n            return (\n              <article className={styles[status]} key={stage.id}>\n                <small>STAGE {String(stage.order).padStart(2, \"0\")}</small>\n                <strong>{stage.name}</strong>\n                <span>{STATUS_LABELS[status]}</span>\n                {history?.notes && <p>{history.notes}</p>}\n              </article>\n            );\n          })}\n        </div>\n      </section>\n\n      <div className={styles.contentGrid}>\n        <section className={styles.section}>\n          <h2>핵심 스킬 갭</h2>\n          <div className={styles.skillList}>\n            {candidate.skill_assessments.map((assessment) => {\n              const skill = skillsById.get(assessment.skill_id);\n              return (\n                <Link href={`/skills/${assessment.skill_id}`} key={assessment.skill_id}>\n                  <div>\n                    <strong>{skill?.preferred_label_ko ?? assessment.skill_id}</strong>\n                    <span>{assessment.skill_id}</span>\n                  </div>\n                  <b>\n                    Lv{assessment.current_level} → Lv{assessment.target_level}\n                  </b>\n                </Link>\n              );\n            })}\n          </div>\n        </section>\n\n        <section className={styles.section}>\n          <h2>5개 직능 역량</h2>\n          <div className={styles.axisList}>\n            {track.competency_axes.map((axis) => {\n              const score =\n                candidate.competency_assessments.find(\n                  (assessment) => assessment.axis_id === axis.id,\n                )?.score ?? 0;\n              return (\n                <div key={axis.id}>\n                  <span>{axis.name}</span>\n                  <div><i style={{ width: `${(score / axis.scale_max) * 100}%` }} /></div>\n                  <strong>{score}/{axis.scale_max}</strong>\n                </div>\n              );\n            })}\n          </div>\n        </section>\n      </div>\n\n      <div className={styles.contentGrid}>\n        <section className={styles.section}>\n          <h2>1人1案 현장 임팩트 과제</h2>\n          {candidate.impact_proposal ? (\n            <article className={styles.proposal}>\n              <span>{IMPACT_STATUS_LABELS[candidate.impact_proposal.status]}</span>\n              <h3>{candidate.impact_proposal.title}</h3>\n              <p>{candidate.impact_proposal.problem}</p>\n              <strong>{candidate.impact_proposal.expected_impact}</strong>\n            </article>\n          ) : (\n            <p className={styles.empty}>아직 등록된 현장 임팩트 과제가 없습니다.</p>\n          )}\n        </section>\n\n        <section className={styles.section}>\n          <h2>다음 단계 진입 조건</h2>\n          {nextStage ? (\n            <>\n              <h3>{nextStage.name}</h3>\n              <p className={styles.description}>{nextStage.description}</p>\n              <ul>\n                {nextStage.completion_evidence.map((evidence) => (\n                  <li key={evidence}>{evidence}</li>\n                ))}\n              </ul>\n              {nextStage.required_skill_ids.length > 0 && (\n                <div className={styles.requirements}>\n                  {nextStage.required_skill_ids.map((skillId) => (\n                    <Link href={`/skills/${skillId}`} key={skillId}>\n                      {skillsById.get(skillId)?.preferred_label_ko ?? skillId}\n                    </Link>\n                  ))}\n                </div>\n              )}\n            </>\n          ) : (\n            <p className={styles.empty}>최종 인증 단계에 도달했습니다.</p>\n          )}\n        </section>\n      </div>\n    </main>\n  );\n}\n\n---\n\"use client\";\n\nimport { FormEvent, useEffect, useMemo, useState } from \"react\";\nimport { ROBOT_DOMAINS } from \"../lib/robotics-data\";\nimport styles from \"./SkillImportanceRating.module.css\";\n\ninterface SkillImportanceRatingProps {\n  skillId: string;\n  defaultDomain: string;\n}\n\ninterface ImportanceRating {\n  id: string;\n  expertName: string;\n  expertDomain: string;\n  score: number;\n  notes: string;\n  createdAt: string;\n}\n\nconst SCORE_LABELS = {\n  1: \"낮음\",\n  2: \"보통 이하\",\n  3: \"보통\",\n  4: \"높음\",\n  5: \"매우 높음\",\n};\n\nfunction getStorageKey(skillId: string) {\n  return `factory-robotics-skillmap:importance-ratings:${skillId}`;\n}\n\nfunction loadRatings(skillId: string): ImportanceRating[] {\n  try {\n    const savedRatings = window.localStorage.getItem(getStorageKey(skillId));\n    return savedRatings ? (JSON.parse(savedRatings) as ImportanceRating[]) : [];\n  } catch {\n    return [];\n  }\n}\n\nfunction createRatingId() {\n  return `${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;\n}\n\nexport default function SkillImportanceRating({\n  skillId,\n  defaultDomain,\n}: SkillImportanceRatingProps) {\n  const [ratings, setRatings] = useState<ImportanceRating[]>([]);\n  const [expertName, setExpertName] = useState(\"\");\n  const [expertDomain, setExpertDomain] = useState(defaultDomain);\n  const [score, setScore] = useState(3);\n  const [notes, setNotes] = useState(\"\");\n  const [message, setMessage] = useState(\"\");\n\n  useEffect(() => {\n    setRatings(loadRatings(skillId));\n  }, [skillId]);\n\n  const summaries = useMemo(\n    () =>\n      ROBOT_DOMAINS.map((domain) => {\n        const domainRatings = ratings.filter(\n          (rating) => rating.expertDomain === domain.key,\n        );\n        const total = domainRatings.reduce(\n          (sum, rating) => sum + rating.score,\n          0,\n        );\n        return {\n          ...domain,\n          count: domainRatings.length,\n          average: domainRatings.length ? total / domainRatings.length : null,\n        };\n      }).filter((summary) => summary.count > 0),\n    [ratings],\n  );\n\n  function saveRatings(nextRatings: ImportanceRating[]) {\n    try {\n      window.localStorage.setItem(\n        getStorageKey(skillId),\n        JSON.stringify(nextRatings),\n      );\n      setRatings(nextRatings);\n      return true;\n    } catch {\n      setMessage(\"평가를 저장하지 못했습니다. 브라우저 저장 공간을 확인해 주세요.\");\n      return false;\n    }\n  }\n\n  function handleSubmit(event: FormEvent<HTMLFormElement>) {\n    event.preventDefault();\n    const trimmedExpertName = expertName.trim();\n    if (!trimmedExpertName) {\n      setMessage(\"평가자를 입력해 주세요.\");\n      return;\n    }\n\n    const nextRatings = [\n      {\n        id: createRatingId(),\n        expertName: trimmedExpertName,\n        expertDomain,\n        score,\n        notes: notes.trim(),\n        createdAt: new Date().toISOString(),\n      },\n      ...ratings,\n    ];\n\n    if (saveRatings(nextRatings)) {\n      setNotes(\"\");\n      setMessage(\"중요도 평가를 저장했습니다.\");\n    }\n  }\n\n  function handleDelete(ratingId: string) {\n    if (saveRatings(ratings.filter((rating) => rating.id !== ratingId))) {\n      setMessage(\"평가를 삭제했습니다.\");\n    }\n  }\n\n  return (\n    <section className={styles.ratingPanel}>\n      <div className={styles.heading}>\n        <div>\n          <p className={styles.eyebrow}>DOMAIN EXPERT RATING</p>\n          <h2>영역별 전문가 중요도 평가</h2>\n          <span>\n            각 영역의 전문가가 현장 관점에서 이 스킬의 중요도를 평가합니다.\n          </span>\n        </div>\n        <strong>{ratings.length}건 기록</strong>\n      </div>\n\n      <form className={styles.ratingForm} onSubmit={handleSubmit}>\n        <label>\n          평가자\n          <input\n            onChange={(event) => setExpertName(event.target.value)}\n            placeholder=\"예: 생산기술팀 김OO\"\n            value={expertName}\n          />\n        </label>\n        <label>\n          전문 영역\n          <select\n            onChange={(event) => setExpertDomain(event.target.value)}\n            value={expertDomain}\n          >\n            {ROBOT_DOMAINS.map((domain) => (\n              <option key={domain.key} value={domain.key}>\n                {domain.name}\n              </option>\n            ))}\n          </select>\n        </label>\n        <fieldset>\n          <legend>중요도</legend>\n          <div className={styles.scoreOptions}>\n            {Object.entries(SCORE_LABELS).map(([value, label]) => {\n              const numericValue = Number(value);\n              return (\n                <label key={value}>\n                  <input\n                    checked={score === numericValue}\n                    name=\"importance-score\"\n                    onChange={() => setScore(numericValue)}\n                    type=\"radio\"\n                    value={value}\n                  />\n                  <strong>{value}</strong>\n                  <span>{label}</span>\n                </label>\n              );\n            })}\n          </div>\n        </fieldset>\n        <label className={styles.notes}>\n          의견 <span>선택</span>\n          <textarea\n            onChange={(event) => setNotes(event.target.value)}\n            placeholder=\"왜 중요한지, 어떤 현장에 필요한지 간단히 남겨 주세요.\"\n            rows={3}\n            value={notes}\n          />\n        </label>\n        <button type=\"submit\">평가 저장</button>\n      </form>\n\n      {message && (\n        <p aria-live=\"polite\" className={styles.message}>\n          {message}\n        </p>\n      )}\n\n      <div className={styles.summarySection}>\n        <h3>영역별 평가 요약</h3>\n        {summaries.length === 0 ? (\n          <p className={styles.empty}>아직 등록된 중요도 평가가 없습니다.</p>\n        ) : (\n          <div className={styles.summaryGrid}>\n            {summaries.map((summary) => (\n              <article key={summary.key}>\n                <span>{summary.name}</span>\n                <strong>{summary.average?.toFixed(1)}</strong>\n                <small>{summary.count}명 평가 · 5점 만점</small>\n              </article>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {ratings.length > 0 && (\n        <div className={styles.historySection}>\n          <h3>최근 평가</h3>\n          <div className={styles.historyList}>\n","tool_use_id":"call_dfgX5NeLgJd1VijWuvIiFPrt"}
