.45rem;\n}\n\n.ratingForm fieldset,\n.notes {\n  grid-column: 1 / -1;\n  border: 0;\n}\n\n.notes span {\n  color: var(--text-muted);\n  font-size: 0.72rem;\n  font-weight: 500;\n}\n\n.scoreOptions {\n  display: grid;\n  grid-template-columns: repeat(5, minmax(0, 1fr));\n  gap: 0.45rem;\n  margin-top: 0.3rem;\n}\n\n.scoreOptions label {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 0.05rem;\n  padding: 0.55rem 0.2rem;\n  cursor: pointer;\n  background: white;\n  border: 1px solid var(--border-color);\n  border-radius: 0.45rem;\n}\n\n.scoreOptions label:has(input:checked) {\n  color: var(--color-primary-dark);\n  background: hsl(262, 83%, 97%);\n  border-color: var(--color-primary);\n}\n\n.scoreOptions input {\n  width: auto;\n  margin: 0;\n}\n\n.scoreOptions span {\n  font-size: 0.72rem;\n  font-weight: 500;\n}\n\n.ratingForm button {\n  justify-self: start;\n  padding: 0.65rem 1rem;\n  color: white;\n  font-weight: 800;\n  cursor: pointer;\n  background: var(--color-primary-dark);\n  border: 0;\n  border-radius: 0.45rem;\n}\n\n.message {\n  margin-top: 0.7rem;\n  color: var(--color-primary-dark);\n  font-size: 0.85rem;\n  font-weight: 700;\n}\n\n.summarySection,\n.historySection {\n  margin-top: 1.2rem;\n}\n\n.summarySection h3,\n.historySection h3 {\n  margin-bottom: 0.55rem;\n  font-size: 0.92rem;\n}\n\n.summaryGrid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));\n  gap: 0.55rem;\n}\n\n.summaryGrid article {\n  display: flex;\n  flex-direction: column;\n  padding: 0.7rem;\n  background: var(--bg-secondary);\n  border-radius: 0.55rem;\n}\n\n.summaryGrid span,\n.summaryGrid small,\n.historyList span,\n.historyList p {\n  color: var(--text-secondary);\n  font-size: 0.78rem;\n}\n\n.summaryGrid strong {\n  color: var(--color-primary-dark);\n  font-size: 1.45rem;\n}\n\n.historyList {\n  display: grid;\n  gap: 0.45rem;\n}\n\n.historyList article {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 0.75rem;\n  padding: 0.7rem;\n  border: 1px solid var(--border-color);\n  border-radius: 0.55rem;\n}\n\n.historyList span {\n  display: block;\n}\n\n.historyList p {\n  margin-top: 0.25rem;\n}\n\n.historyList button {\n  color: hsl(0, 65%, 40%);\n  font-weight: 700;\n  cursor: pointer;\n  background: transparent;\n  border: 0;\n}\n\n@media (max-width: 560px) {\n  .heading,\n  .ratingForm {\n    display: block;\n  }\n\n  .heading > strong {\n    display: inline-block;\n    margin-top: 0.5rem;\n  }\n\n  .ratingForm > * + * {\n    display: block;\n    margin-top: 0.8rem;\n  }\n\n  .scoreOptions {\n    gap: 0.25rem;\n  }\n\n  .scoreOptions span {\n    font-size: 0.62rem;\n  }\n}\n","tool_use_id":"call_Od2YWd5803GecgxdP5ui30tp"}
