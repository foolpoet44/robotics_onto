2026-06-03T01:17:56.947Z PostToolUse status=unknown {"session_id":"019e8b0b-e27d-7de0-bebf-b43fe290f845","turn_id":"019e8b0b-e364-7672-ae02-9112e9c39dc8","transcript_path":null,"cwd":"/Users/dkmac/Desktop/@26/factory-robotics-skillmap","hook_event_name":"PostToolUse","model":"gpt-5.4","permission_mode":"bypassPermissions","tool_name":"Bash","tool_input":{"command":"sed -n '1,260p' app/components/SkillImportanceRating.tsx"},"tool_response":"\"use client\";\n\nimport { FormEvent, useEffect, useMemo, useState } from \"react\";\nimport { ROBOT_DOMAINS } from \"../lib/robotics-data\";\nimport styles from \"./SkillImportanceRating.module.css\";\n\ninterface SkillImportanceRatingProps {\n  skillId: string;\n  defaultDomain: string;\n}\n\ninterface ImportanceRating {\n  id: string;\n  expertName: string;\n  expertDomain: string;\n  score: number;\n  notes: string;\n  createdAt: string;\n}\n\nconst SCORE_LABELS = {\n  1: \"낮음\",\n  2: \"보통 이하\",\n  3: \"보통\",\n  4: \"높음\",\n  5: \"매우 높음\",\n};\n\nfunction getStorageKey(skillId: string) {\n  return `factory-robotics-skillmap:importance-ratings:${skillId}`;\n}\n\nfunction loadRatings(skillId: string): ImportanceRating[] {\n  try {\n    const savedRatings = window.localStorage.getItem(getStorageKey(skillId));\n    return savedRatings ? (JSON.parse(savedRatings) as ImportanceRating[]) : [];\n  } catch {\n    return [];\n  }\n}\n\nfunction createRatingId() {\n  return `${Date.now()}-${Math.random().toString(36).slice(2, 9)}`;\n}\n\nexport default function SkillImportanceRating({\n  skillId,\n  defaultDomain,\n}: SkillImportanceRatingProps) {\n  const [ratings, setRatings] = useState<ImportanceRating[]>([]);\n  const [expertName, setExpertName] = useState(\"\");\n  const [expertDomain, setExpertDomain] = useState(defaultDomain);\n  const [score, setScore] = useState(3);\n  const [notes, setNotes] = useState(\"\");\n  const [message, setMessage] = useState(\"\");\n\n  useEffect(() => {\n    setRatings(loadRatings(skillId));\n  }, [skillId]);\n\n  const summaries = useMemo(\n    () =>\n      ROBOT_DOMAINS.map((domain) => {\n        const domainRatings = ratings.filter(\n          (rating) => rating.expertDomain === domain.key,\n        );\n        const total = domainRatings.reduce(\n          (sum, rating) => sum + rating.score,\n          0,\n        );\n        return {\n          ...domain,\n          count: domainRatings.length,\n          average: domainRatings.length ? total / domainRatings.length : null,\n        };\n      }).filter((summary) => summary.count > 0),\n    [ratings],\n  );\n\n  function saveRatings(nextRatings: ImportanceRating[]) {\n    try {\n      window.localStorage.setItem(\n        getStorageKey(skillId),\n        JSON.stringify(nextRatings),\n      );\n      setRatings(nextRatings);\n      return true;\n    } catch {\n      setMessage(\"평가를 저장하지 못했습니다. 브라우저 저장 공간을 확인해 주세요.\");\n      return false;\n    }\n  }\n\n  function handleSubmit(event: FormEvent<HTMLFormElement>) {\n    event.preventDefault();\n    const trimmedExpertName = expertName.trim();\n    if (!trimmedExpertName) {\n      setMessage(\"평가자를 입력해 주세요.\");\n      return;\n    }\n\n    const nextRatings = [\n      {\n        id: createRatingId(),\n        expertName: trimmedExpertName,\n        expertDomain,\n        score,\n        notes: notes.trim(),\n        createdAt: new Date().toISOString(),\n      },\n      ...ratings,\n    ];\n\n    if (saveRatings(nextRatings)) {\n      setNotes(\"\");\n      setMessage(\"중요도 평가를 저장했습니다.\");\n    }\n  }\n\n  function handleDelete(ratingId: string) {\n    if (saveRatings(ratings.filter((rating) => rating.id !== ratingId))) {\n      setMessage(\"평가를 삭제했습니다.\");\n    }\n  }\n\n  return (\n    <section className={styles.ratingPanel}>\n      <div className={styles.heading}>\n        <div>\n          <p className={styles.eyebrow}>DOMAIN EXPERT RATING</p>\n          <h2>영역별 전문가 중요도 평가</h2>\n          <span>\n            각 영역의 전문가가 현장 관점에서 이 스킬의 중요도를 평가합니다.\n          </span>\n        </div>\n        <strong>{ratings.length}건 기록</strong>\n      </div>\n\n      <form className={styles.ratingForm} onSubmit={handleSubmit}>\n        <label>\n          평가자\n          <input\n            onChange={(event) => setExpertName(event.target.value)}\n            placeholder=\"예: 생산기술팀 김OO\"\n            value={expertName}\n          />\n        </label>\n        <label>\n          전문 영역\n          <select\n            onChange={(event) => setExpertDomain(event.target.value)}\n            value={expertDomain}\n          >\n            {ROBOT_DOMAINS.map((domain) => (\n              <option key={domain.key} value={domain.key}>\n                {domain.name}\n              </option>\n            ))}\n          </select>\n        </label>\n        <fieldset>\n          <legend>중요도</legend>\n          <div className={styles.scoreOptions}>\n            {Object.entries(SCORE_LABELS).map(([value, label]) => {\n              const numericValue = Number(value);\n              return (\n                <label key={value}>\n                  <input\n                    checked={score === numericValue}\n                    name=\"importance-score\"\n                    onChange={() => setScore(numericValue)}\n                    type=\"radio\"\n                    value={value}\n                  />\n                  <strong>{value}</strong>\n                  <span>{label}</span>\n                </label>\n              );\n            })}\n          </div>\n        </fieldset>\n        <label className={styles.notes}>\n          의견 <span>선택</span>\n          <textarea\n            onChange={(event) => setNotes(event.target.value)}\n            placeholder=\"왜 중요한지, 어떤 현장에 필요한지 간단히 남겨 주세요.\"\n            rows={3}\n            value={notes}\n          />\n        </label>\n        <button type=\"submit\">평가 저장</button>\n      </form>\n\n      {message && (\n        <p aria-live=\"polite\" className={styles.message}>\n          {message}\n        </p>\n      )}\n\n      <div className={styles.summarySection}>\n        <h3>영역별 평가 요약</h3>\n        {summaries.length === 0 ? (\n          <p className={styles.empty}>아직 등록된 중요도 평가가 없습니다.</p>\n        ) : (\n          <div className={styles.summaryGrid}>\n            {summaries.map((summary) => (\n              <article key={summary.key}>\n                <span>{summary.name}</span>\n                <strong>{summary.average?.toFixed(1)}</strong>\n                <small>{summary.count}명 평가 · 5점 만점</small>\n              </article>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {ratings.length > 0 && (\n        <div className={styles.historySection}>\n          <h3>최근 평가</h3>\n          <div className={styles.historyList}>\n            {ratings.slice(0, 5).map((rating) => {\n              const domainName =\n                ROBOT_DOMAINS.find((domain) => domain.key === rating.expertDomain)\n                  ?.name ?? rating.expertDomain;\n              return (\n                <article key={rating.id}>\n                  <div>\n                    <strong>\n                      {rating.score}점 · {rating.expertName}\n                    </strong>\n                    <span>\n                      {domainName} ·{\" \"}\n                      {new Intl.DateTimeFormat(\"ko-KR\", {\n                        dateStyle: \"medium\",\n                      }).format(new Date(rating.createdAt))}\n                    </span>\n                    {rating.notes && <p>{rating.notes}</p>}\n                  </div>\n                  <button\n                    onClick={() => handleDelete(rating.id)}\n                    type=\"button\"\n                  >\n                    삭제\n                  </button>\n                </article>\n              );\n            })}\n          </div>\n        </div>\n      )}\n    </section>\n  );\n}\n","tool_use_id":"call_tm2yOohFVmXjVLBZyujdDRCo"}
2026-06-03T01:17:56.947Z PostToolUse status=unknown {"session_id":"019e8b0b-e27d-7de0-bebf-b43fe290f845","turn_id":"019e8b0b-e364-7672-ae02-9112e9c39dc8","transcript_path":null,"cwd":"/Users/dkmac/Desktop/@26/factory-robotics-skillmap","hook_event_name":"PostToolUse","model":"gpt-5.4","permission_mode":"bypassPermissions","tool_name":"Bash","tool_input":{"command":"sed -n '1,220p' app/reviews/page.tsx"},"tool_response":"import Link from \"next/link\";\nimport { ReviewItem } from \"../lib/review-data\";\nimport { getReviewQueue } from \"../lib/server-data\";\nimport styles from \"./page.module.css\";\n\nconst RELATION_LABELS = {\n  prerequisite: \"선행 관계\",\n  co_required: \"동반 관계\",\n  specialization: \"특화 관계\",\n  cross_domain: \"도메인 연결\",\n};\n\nconst BIDIRECTIONAL_RELATIONS = new Set([\"co_required\", \"cross_domain\"]);\nconst STATUS_LABELS = {\n  pending: \"검수 대기\",\n  approved: \"승인\",\n  held: \"보류\",\n  rejected: \"반려\",\n};\n\nfunction SkillLink({\n  skill,\n}: {\n  skill: { skill_id: string; label_ko: string; domain: string };\n}) {\n  return (\n    <Link href={`/skills/${skill.skill_id}`}>\n      {skill.label_ko}\n      <small>{skill.skill_id}</small>\n    </Link>\n  );\n}\n\nfunction ReviewCard({ item }: { item: ReviewItem }) {\n  if (item.kind === \"organization_mapping\") {\n    return (\n      <article className={styles.reviewCard}>\n        <header>\n          <span className={styles.highPriority}>우선 검수</span>\n          <span>조직 역량 매핑</span>\n          <span className={styles[item.status]}>{STATUS_LABELS[item.status]}</span>\n        </header>\n        <h2>{item.organization_skill.label_ko}</h2>\n        <p>\n          {item.organization_name} · {item.enabler_name}\n        </p>\n        <div className={styles.mapping}>\n          <strong>{item.organization_skill.skill_id}</strong>\n          <span>→</span>\n          <SkillLink skill={item.ontology_skill} />\n        </div>\n        <p className={styles.question}>\n          두 역량을 같은 기준 스킬로 연결해도 되는지 확인해 주세요.\n        </p>\n        {item.decision && (\n          <p className={styles.decision}>\n            {item.decision.reviewer} · {item.decision.reviewed_at}\n          </p>\n        )}\n      </article>\n    );\n  }\n\n  return (\n    <article className={styles.reviewCard}>\n      <header>\n        <span className={styles[item.priority]}>관계 후보</span>\n        <span>{RELATION_LABELS[item.relation_type]}</span>\n        <span className={styles[item.status]}>{STATUS_LABELS[item.status]}</span>\n      </header>\n      <div className={styles.mapping}>\n        <SkillLink skill={item.source_skill} />\n        <span>\n          {BIDIRECTIONAL_RELATIONS.has(item.relation_type) ? \"↔\" : \"→\"}\n        </span>\n        <SkillLink skill={item.target_skill} />\n      </div>\n      <p className={styles.question}>\n        현장 역량 관점에서 이 연결이 유효한지 확인해 주세요.\n      </p>\n      {item.decision && (\n        <p className={styles.decision}>\n          {item.decision.reviewer} · {item.decision.reviewed_at}\n        </p>\n      )}\n    </article>\n  );\n}\n\nexport default async function ReviewsPage() {\n  const queue = await getReviewQueue();\n  const highPriorityItems = queue.items.filter(\n    (item) => item.status === \"pending\" && item.priority === \"high\",\n  );\n  const normalItems = queue.items.filter(\n    (item) => item.status === \"pending\" && item.priority === \"normal\",\n  );\n  const recordedItems = queue.items.filter((item) => item.status !== \"pending\");\n\n  return (\n    <main className={styles.pageShell}>\n      <header className={styles.pageHeading}>\n        <p>EXPERT REVIEW QUEUE</p>\n        <h1>현장 전문가 검수 큐</h1>\n        <span>\n          자동 생성된 후보입니다. 연결을 확정하기 전에 HR·현장 전문가의 판단이\n          필요합니다.\n        </span>\n      </header>\n\n      <section className={styles.summaryGrid} aria-label=\"검수 큐 요약\">\n        <div>\n          <strong>{queue.stats.total}</strong>\n          <span>전체 후보</span>\n        </div>\n        <div>\n          <strong>{queue.stats.organizationMappings}</strong>\n          <span>조직 근사 매핑</span>\n        </div>\n        <div>\n          <strong>{queue.stats.ontologyRelations}</strong>\n          <span>온톨로지 관계</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.pending}</strong>\n          <span>검수 대기</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.approved}</strong>\n          <span>승인</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.held}</strong>\n          <span>보류</span>\n        </div>\n        <div>\n          <strong>{queue.stats.statuses.rejected}</strong>\n          <span>반려</span>\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>우선 검수</h2>\n        <p>근사 매핑과 도메인 간 연결처럼 판단 영향이 큰 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {highPriorityItems.length === 0 ? (\n            <p>우선 검수 대기 항목이 없습니다.</p>\n          ) : (\n            highPriorityItems.map((item) => (\n              <ReviewCard item={item} key={item.id} />\n            ))\n          )}\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>일반 검수</h2>\n        <p>같은 도메인 안에서 자동 생성된 관계 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {normalItems.map((item) => (\n            <ReviewCard item={item} key={item.id} />\n          ))}\n        </div>\n      </section>\n\n      <section className={styles.section}>\n        <h2>검수 기록</h2>\n        <p>승인·보류·반려가 기록된 후보입니다.</p>\n        <div className={styles.reviewGrid}>\n          {recordedItems.length === 0 ? (\n            <p>아직 기록된 검수 결과가 없습니다.</p>\n          ) : (\n            recordedItems.map((item) => (\n              <ReviewCard item={item} key={item.id} />\n            ))\n          )}\n        </div>\n      </section>\n    </main>\n  );\n}\n","tool_use_id":"call_oiUyKJVPo9V849Al6Ue0V95e"}
