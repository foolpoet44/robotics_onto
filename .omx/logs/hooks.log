string;\n    39\t  enablerCount: number;\n    40\t  skillCount: number;\n    41\t}\n    42\t\n    43\texport const ORGANIZATION_IDS = [\"robot-solution\"] as const;\n\n--- ORG DETAIL ---\n     1\timport Link from \"next/link\";\n     2\timport { notFound } from \"next/navigation\";\n     3\timport EmptyState from \"../../components/EmptyState\";\n     4\timport { getOrganization, getOrganizationIds } from \"../../lib/server-data\";\n     5\timport styles from \"./page.module.css\";\n     6\t\n     7\texport function generateStaticParams() {\n     8\t  return getOrganizationIds().map((orgId) => ({ orgId }));\n     9\t}\n    10\t\n    11\texport default async function OrganizationDetailPage({\n    12\t  params,\n    13\t}: {\n    14\t  params: Promise<{ orgId: string }>;\n    15\t}) {\n    16\t  const { orgId } = await params;\n    17\t  const organization = await getOrganization(orgId);\n    18\t  if (!organization) {\n    19\t    notFound();\n    20\t  }\n    21\t\n    22\t  const { organization: info, enablers } = organization;\n    23\t  const totalSkills = enablers.reduce(\n    24\t    (sum, enabler) => sum + enabler.skills.length,\n    25\t    0,\n    26\t  );\n    27\t\n    28\t  return (\n    29\t    <main className={styles.pageShell}>\n    30\t      <Link href=\"/organizations\" className={styles.backLink}>\n    31\t        ← 조직 목록\n    32\t      </Link>\n    33\t      <header className={styles.organizationHeading}>\n    34\t        <div>\n    35\t          <p className={styles.eyebrow}>ROBOTICS ORGANIZATION</p>\n    36\t          <h1>🤖 {info.name}</h1>\n    37\t          <p>{info.name_en}</p>\n    38\t          <p>{info.description}</p>\n    39\t        </div>\n    40\t        <div className={styles.summary}>\n    41\t          <strong>{enablers.length}</strong>\n    42\t          <span>Enablers</span>\n    43\t          <strong>{totalSkills}</strong>\n    44\t          <span>Mapped Skills</span>\n    45\t        </div>\n    46\t      </header>\n    47\t\n    48\t      {info.mission_detail && (\n    49\t        <section className={styles.section}>\n    50\t          <h2>조직 미션</h2>\n    51\t          <div className={styles.panel}>\n    52\t            <p>{info.mission_detail}</p>\n    53\t          </div>\n    54\t        </section>\n    55\t      )}\n    56\t\n    57\t      {info.challenges && (\n    58\t        <section className={styles.section}>\n    59\t          <h2>주요 도전 과제</h2>\n    60\t          <div className={styles.challengeGrid}>\n    61\t            {info.challenges.map((challenge) => (\n    62\t              <article className={styles.panel} key={challenge.title}>\n    63\t                <h3>{challenge.title}</h3>\n    64\t                <ul>\n    65\t                  {challenge.items.map((item) => (\n    66\t                    <li key={item}>{item}</li>\n    67\t                  ))}\n    68\t                </ul>\n    69\t              </article>\n    70\t            ))}\n    71\t          </div>\n    72\t        </section>\n    73\t      )}\n    74\t\n    75\t      <section className={styles.section}>\n    76\t        <h2>Enablers와 필요 스킬</h2>\n    77\t        {enablers.length === 0 ? (\n    78\t          <EmptyState message=\"등록된 조직 역량이 없습니다.\" />\n    79\t        ) : (\n    80\t          <div className={styles.enablerList}>\n    81\t            {enablers.map((enabler) => (\n    82\t              <article className={styles.enablerCard} key={enabler.id}>\n    83\t                <header>\n    84\t                  <div>\n    85\t                    <p className={styles.priority}>PRIORITY {enabler.priority}</p>\n    86\t                    <h3>{enabler.name}</h3>\n    87\t                    <p>{enabler.name_en}</p>\n    88\t                  </div>\n    89\t                  <strong>{enabler.skills.length} Skills</strong>\n    90\t                </header>\n    91\t                <p className={styles.description}>{enabler.description}</p>\n    92\t                <div className={styles.skillTable}>\n    93\t                  {enabler.skills.map((skill) => (\n    94\t                    <div className={styles.skillRow} key={skill.skill_id}>\n    95\t                      <div>\n    96\t                        <b>{skill.label_ko}</b>\n    97\t                        <span>{skill.label_en}</span>\n    98\t                      </div>\n    99\t                      <span>중요도 {skill.importance}</span>\n   100\t                      <span>{skill.target_proficiency}</span>\n   101\t                    </div>\n   102\t                  ))}\n   103\t                </div>\n   104\t              </article>\n   105\t            ))}\n   106\t          </div>\n   107\t        )}\n   108\t      </section>\n   109\t    </main>\n   110\t  );\n   111\t}\n\n--- SERVER DATA ---\n     1\timport { readFile } from \"node:fs/promises\";\n     2\timport path from \"node:path\";\n     3\timport {\n     4\t  ORGANIZATION_IDS,\n     5\t  Organization,\n     6\t  OrganizationSummary,\n     7\t} from \"./organization-data\";\n     8\timport { RobotSkill } from \"./robotics-data\";\n     9\t\n    10\tasync function readJsonFile<T>(relativePath: string): Promise<T> {\n    11\t  const filePath = path.join(process.cwd(), \"public\", \"data\", relativePath);\n    12\t  const content = await readFile(filePath, \"utf-8\");\n    13\t  return JSON.parse(content) as T;\n    14\t}\n    15\t\n    16\texport async function getAllRobotSkills(): Promise<RobotSkill[]> {\n    17\t  return readJsonFile<RobotSkill[]>(\"robot-smartfactory.json\");\n    18\t}\n    19\t\n    20\texport async function getDomainSkills(domainKey: string): Promise<RobotSkill[]> {\n    21\t  const skills = await getAllRobotSkills();\n    22\t  return skills.filter((skill) => skill.domain === domainKey);\n    23\t}\n    24\t\n    25\texport function getOrganizationIds(): string[] {\n    26\t  return [...ORGANIZATION_IDS];\n    27\t}\n    28\t\n    29\texport async function getOrganization(\n    30\t  orgId: string,\n    31\t): Promise<Organization | null> {\n    32\t  if (!getOrganizationIds().includes(orgId)) {\n    33\t    return null;\n    34\t  }\n    35\t  return readJsonFile<Organization>(`organizations/${orgId}.json`);\n    36\t}\n    37\t\n    38\texport async function getOrganizationSummaries(): Promise<\n    39\t  OrganizationSummary[]\n    40\t> {\n    41\t  const summaries = await Promise.all(\n    42\t    getOrganizationIds().map(async (id) => {\n    43\t      const data = await getOrganization(id);\n    44\t      if (!data) {\n    45\t        throw new Error(`조직 데이터를 찾을 수 없습니다: ${id}`);\n    46\t      }\n    47\t      return {\n    48\t        id,\n    49\t        name: data.organization.name,\n    50\t        nameEn: data.organization.name_en,\n    51\t        description: data.organization.description,\n    52\t        enablerCount: data.enablers.length,\n    53\t        skillCount: data.enablers.reduce(\n    54\t          (total, enabler) => total + enabler.skills.length,\n    55\t          0,\n    56\t        ),\n    57\t      };\n    58\t    }),\n    59\t  );\n    60\t  return summaries;\n    61\t}\n\n--- ONTOLOGY VALIDATION ---\n     1\tconst ALLOWED_RELATION_TYPES = new Set([\n     2\t  \"prerequisite\",\n     3\t  \"co_required\",\n     4\t  \"specialization\",\n     5\t  \"cross_domain\",\n     6\t]);\n     7\tconst ALLOWED_SKILL_TYPES = new Set([\"knowledge\", \"skill\", \"competence\"]);\n     8\tconst ALLOWED_ROLES = new Set([\"operator\", \"engineer\", \"developer\"]);\n     9\tconst ALLOWED_PROFICIENCY_LEVELS = new Set([1, 2, 3, 4]);\n    10\t\n    11\tfunction getRelationTarget(relation) {\n    12\t  return typeof relation === \"string\" ? relation : relation?.target;\n    13\t}\n    14\t\n    15\tfunction getRelationType(relation) {\n    16\t  return typeof relation === \"string\" ? null : relation?.type;\n    17\t}\n    18\t\n    19\tfunction findParentCycles(skillsById) {\n    20\t  const cycles = [];\n    21\t  const completed = new Set();\n    22\t\n    23\t  for (const skillId of skillsById.keys()) {\n    24\t    if (completed.has(skillId)) continue;\n    25\t\n    26\t    const path = [];\n    27\t    const pathIndexes = new Map();\n    28\t    let currentId = skillId;\n    29\t\n    30\t    while (currentId && skillsById.has(currentId)) {\n    31\t      if (pathIndexes.has(currentId)) {\n    32\t        cycles.push([...path.slice(pathIndexes.get(currentId)), currentId]);\n    33\t        break;\n    34\t      }\n    35\t      if (completed.has(currentId)) break;\n    36\t\n    37\t      pathIndexes.set(currentId, path.length);\n    38\t      path.push(currentId);\n    39\t      currentId = skillsById.get(currentId).parent_skill_id;\n    40\t    }\n    41\t\n    42\t    path.forEach((id) => completed.add(id));\n    43\t  }\n    44\t\n    45\t  return cycles;\n    46\t}\n    47\t\n    48\tfunction validateOntologySemantics(skills) {\n    49\t  const errors = [];\n    50\t  const warnings = [];\n    51\t  const skillsById = new Map(skills.map((skill) => [skill.skill_id, skill]));\n    52\t  let edgeCount = 0;\n    53\t\n    54\t  for (const skill of skills) {\n    55\t    const relations = Array.isArray(skill.related_skills)\n    56\t      ? skill.related_skills\n    57\t      : [];\n    58\t    edgeCount += relations.length;\n    59\t\n    60\t    if (!ALLOWED_SKILL_TYPES.has(skill.skill_type)) {\n    61\t      errors.push(\n    62\t        `${skill.skill_id}: 허용되지 않은 skill_type '${skill.skill_type}'`,\n    63\t      );\n    64\t    }\n    65\t    if (!ALLOWED_PROFICIENCY_LEVELS.has(skill.proficiency_level)) {\n    66\t      errors.push(\n    67\t        `${skill.skill_id}: 허용되지 않은 proficiency_level '${skill.proficiency_level}'`,\n    68\t      );\n    69\t    }\n    70\t    if (!Array.isArray(skill.role_mapping) || skill.role_mapping.length === 0) {\n    71\t      errors.push(`${skill.skill_id}: role_mapping이 비어 있습니다.`);\n    72\t    } else {\n    73\t      skill.role_mapping.forEach((role) => {\n    74\t        if (!ALLOWED_ROLES.has(role)) {\n    75\t          errors.push(`${skill.skill_id}: 허용되지 않은 role_mapping '${role}'`);\n    76\t        }\n    77\t      });\n    78\t    }\n    79\t\n    80\t    if (skill.parent_skill_id && !skillsById.has(skill.parent_skill_id)) {\n    81\t      errors.push(\n    82\t        `${skill.skill_id}: 존재하지 않는 parent_skill_id '${skill.parent_skill_id}'`,\n    83\t      );\n    84\t    }\n    85\t\n    86\t    if (\n    87\t      skill.esco_uri &&\n    88\t      skill.esco_uri.includes(\"data.europa.eu/esco\") &&\n    89\t      skill.esco_uri.includes(\"rsf-\")\n    90\t    ) {\n    91\t      errors.push(`${skill.skill_id}: 가짜 ESCO URI '${skill.esco_uri}'`);\n    92\t    }\n    93\t    if (!skill.internal_uri && !skill.esco_uri) {\n    94\t      errors.push(`${skill.skill_id}: internal_uri 또는 esco_uri가 필요합니다.`);\n    95\t    }\n    96\t    if (skill.internal_uri && !skill.internal_uri.startsWith(\"urn:rsf:skill:\")) {\n    97\t      errors.push(`${skill.skill_id}: 잘못된 internal_uri '${skill.internal_uri}'`);\n    98\t    }\n    99\t\n   100\t    relations.forEach((relation) => {\n   101\t      const target = getRelationTarget(relation);\n   102\t      if (!target || !skillsById.has(target)) {\n   103\t        errors.push(\n   104\t          `${skill.skill_id}: 존재하지 않는 related_skills 참조 '${target}'`,\n   105\t        );\n   106\t      }\n   107\t\n   108\t      const type = getRelationType(relation);\n   109\t      if (type && !ALLOWED_RELATION_TYPES.has(type)) {\n   110\t        errors.push(`${skill.skill_id}: 허용되지 않은 관계 유형 '${type}'`);\n   111\t      }\n   112\t      if (type === \"co_required\" || type === \"cross_domain\") {\n   113\t        const reverseRelations = skillsById.get(target)?.related_skills ?? [];\n   114\t        const hasReverse = reverseRelations.some(\n   115\t          (reverseRelation) =>\n   116\t            getRelationTarget(reverseRelation) === skill.skill_id &&\n   117\t            getRelationType(reverseRelation) === type,\n   118\t        );\n   119\t        if (!hasReverse) {\n   120\t          warnings.push(\n   121\t            `${skill.skill_id} -> ${target}: 대칭 관계 '${type}'의 역방향 누락`,\n   122\t          );\n   123\t        }\n   124\t      }\n   125\t    });\n   126\t  }\n   127\t\n   128\t  const isolatedCount = skills.filter(\n   129\t    (skill) =>\n   130\t      !Array.isArray(skill.related_skills) || skill.related_skills.length === 0,\n   131\t  ).length;\n   132\t  const averageEdges = skills.length === 0 ? 0 : edgeCount / skills.length;\n   133\t  const overConnected = skills.filter(\n   134\t    (skill) =>\n   135\t      Array.isArray(skill.related_skills) && skill.related_skills.length > 8,\n   136\t  );\n   137\t\n   138\t  if (isolatedCount > 0) {\n   139\t    errors.push(`고립 노드 ${isolatedCount}개: related_skills가 비어 있습니다.`);\n   140\t  }\n   141\t  if (averageEdges < 2) {\n   142\t    errors.push(`평균 관계 ${averageEdges.toFixed(2)}개: 최소 기준 2개 미달`);\n   143\t  }\n   144\t  if (overConnected.length > 0) {\n   145\t    errors.push(`과연결 노드 ${overConnected.length}개: 관계 상한 8개 초과`);\n   146\t  }\n   147\t\n   148\t  findParentCycles(skillsById).forEach((cycle) => {\n   149\t    errors.push(`부모 관계 순환: ${cycle.join(\" -> \")}`);\n   150\t  });\n   151\t\n   152\t  return {\n   153\t    valid: errors.length === 0,\n   154\t    errors,\n   155\t    warnings,\n   156\t    metrics: {\n   157\t      skills: skills.length,\n   158\t      edges: edgeCount,\n   159\t      averageEdges,\n   160\t      isolated: isolatedCount,\n   161\t    },\n   162\t  };\n   163\t}\n   164\t\n   165\tmodule.exports = {\n   166\t  getRelationTarget,\n   167\t  validateOntologySemantics,\n   168\t};\n","tool_use_id":"call_DcluYQG6OyjrG8LN8EOlYOy1"}
