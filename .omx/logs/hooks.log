     \"order\": 3,\n      \"name\": \"페어 임베드\",\n      \"description\": \"동료와 함께 Production 솔루션 1건을 완수하는 단계\",\n      \"target_headcount\": 38,\n      \"completion_evidence\": [\"Production 솔루션 1건\", \"현장 리뷰\"],\n      \"required_skill_ids\": [\"RSF-CRO-006\", \"RSF-DTS-001\"]\n    },\n    {\n      \"id\": \"solo_embed\",\n      \"order\": 4,\n      \"name\": \"솔로 임베드\",\n      \"description\": \"단독으로 현장 과제를 해결하는 단계\",\n      \"target_headcount\": 32,\n      \"completion_evidence\": [\"단독 과제 해결\", \"1人1案 승인\"],\n      \"required_skill_ids\": [\"RSF-RMD-019\"]\n    },\n    {\n      \"id\": \"lv3_certification\",\n      \"order\": 5,\n      \"name\": \"Lv3 Tech Leader 인증\",\n      \"description\": \"스마트팩토리 솔루션 사업을 이끌 인증 인재\",\n      \"target_headcount\": 30,\n      \"completion_evidence\": [\"육성위원회 인증\", \"확산 계획 발표\"],\n      \"required_skill_ids\": []\n    }\n  ]\n}\n","tool_use_id":"call_oHPG6kEhIFqJ82iobtn1pB2c"}
